---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import OfflineToast from '../components/OfflineToast';
import '../styles/global.css';
import * as m from '../paraglide/messages.js';
import type { SupportedLocale } from '../types/i18n';
import { OG_LOCALE_MAP, SITE_NAME, getCanonicalPath, getAlternateUrls, buildHreflangCluster, SUPPORTED_LOCALES, localizeUrl } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  /** Override auto-generated hreflang links (e.g. for dynamic topic slugs). */
  alternateUrls?: Record<SupportedLocale, string>;
}

const {
  title,
  description = 'Адаптивная платформа подготовки к ОГЭ по химии',
  canonicalUrl,
  ogImage,
  alternateUrls: alternateUrlsOverride,
} = Astro.props;

const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;
const siteName = SITE_NAME[locale];
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = canonicalUrl ?? Astro.url.href;

// i18n: get canonical path and alternate URLs for hreflang
const { canonical: canonicalPath } = getCanonicalPath(Astro.url.pathname);
const alternateUrls = alternateUrlsOverride ?? getAlternateUrls(canonicalPath);

// Breadcrumb segments from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
// Strip locale prefix from breadcrumb segments
const contentSegments = (SUPPORTED_LOCALES as readonly string[]).includes(pathSegments[0])
  ? pathSegments.slice(1)
  : pathSegments;

// Map canonical route slugs to localized nav labels
const ROUTE_LABELS: Record<string, string> = {
  'diagnostics': m.nav_diagnostics(),
  'diagnostyka': m.nav_diagnostics(),
  'diagnostico': m.nav_diagnostics(),
  'periodic-table': m.nav_elements(),
  'tablica-okresowa': m.nav_elements(),
  'tabla-periodica': m.nav_elements(),
  'substances': m.nav_substances(),
  'substancje': m.nav_substances(),
  'sustancias': m.nav_substances(),
  'bonds': m.nav_bonds(),
  'wiazania': m.nav_bonds(),
  'enlaces': m.nav_bonds(),
  'oxidation-states': m.nav_oxidation_states(),
  'stopnie-utlenienia': m.nav_oxidation_states(),
  'estados-oxidacion': m.nav_oxidation_states(),
  'reactions': m.nav_reactions(),
  'reakcje': m.nav_reactions(),
  'reacciones': m.nav_reactions(),
  'calculations': m.nav_calculations(),
  'obliczenia': m.nav_calculations(),
  'calculos': m.nav_calculations(),
  'exam': m.nav_exam(),
  'egzamin': m.nav_exam(),
  'examen': m.nav_exam(),
  'profile': m.nav_profile(),
  'profil': m.nav_profile(),
  'perfil': m.nav_profile(),
  'search': m.nav_search(),
  'szukaj': m.nav_search(),
  'buscar': m.nav_search(),
  'ions': m.nav_ions(),
  'jony': m.nav_ions(),
  'iones': m.nav_ions(),
  'competencies': m.nav_competencies(),
  'kompetencje': m.nav_competencies(),
  'competencias': m.nav_competencies(),
  'processes': m.nav_processes(),
  'procesy': m.nav_processes(),
  'procesos': m.nav_processes(),
  'physical-foundations': m.nav_physical_foundations(),
  'settings': m.nav_settings(),
  'ustawienia': m.nav_settings(),
  'ajustes': m.nav_settings(),
};

function breadcrumbName(seg: string, isLast: boolean): string {
  if (isLast) return title;
  if (ROUTE_LABELS[seg]) return ROUTE_LABELS[seg];
  // Prettify: decode URI, replace hyphens with spaces, capitalize first letter
  const decoded = decodeURIComponent(seg);
  const pretty = decoded.replace(/-/g, ' ');
  return pretty.charAt(0).toUpperCase() + pretty.slice(1);
}

// Build URL segments preserving locale prefix
const localePrefix = (SUPPORTED_LOCALES as readonly string[]).includes(pathSegments[0])
  ? `/${pathSegments[0]}` : '';
const breadcrumbItems = [
  { name: m.breadcrumb_home(), url: `${siteUrl}/` },
  ...contentSegments.map((seg, i) => ({
    name: breadcrumbName(seg, i === contentSegments.length - 1),
    url: `${siteUrl}${localePrefix}/${contentSegments.slice(0, i + 1).join('/')}/`,
  })),
];
const breadcrumbLd = contentSegments.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url,
  })),
} : null;

const searchUrl = localizeUrl('/search/', locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#2563eb" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang alternate links (two-host: global + RU) -->
    {buildHreflangCluster(canonicalPath).map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={OG_LOCALE_MAP[locale]} />
    {SUPPORTED_LOCALES.filter(l => l !== locale).map(l => (
      <meta property="og:locale:alternate" content={OG_LOCALE_MAP[l]} />
    ))}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage ?? `${siteUrl}/og-default.webp`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ?? `${siteUrl}/og-default.webp`} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <!-- Organization structured data (global) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Химия без магии",
      "alternateName": "Chemistry Without Magic",
      "url": siteUrl,
      "logo": `${siteUrl}/icons/icon-512.png`,
      "sameAs": ["https://github.com/dronsv/chemistry-no-magic"],
    })} />

    <!-- Breadcrumb structured data -->
    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}

    <ViewTransitions />

    <!-- RSS/Atom feed -->
    <link rel="alternate" type="application/rss+xml" href="/feed.xml" title="Химия без магии" />

    <!-- DNS prefetch for analytics and CDN -->
    <link rel="dns-prefetch" href="https://storage.yandexcloud.net" />
    <link rel="preconnect" href="https://storage.yandexcloud.net" crossorigin />
    <link rel="dns-prefetch" href="https://mc.yandex.ru" />
    <link rel="preconnect" href="https://mc.yandex.ru" crossorigin />

    <!-- Yandex.Metrika counter — deferred to not block rendering -->
    <script is:inline>
      // Track ViewTransitions page navigations (listener registered early)
      document.addEventListener('astro:page-load', function() {
        if (typeof ym !== 'undefined') {
          ym(106842347, 'hit', location.href, { referer: document.referrer });
        }
      });
      // Defer Metrika loading until browser is idle
      (function(){
        function loadMetrika() {
          (function(m,e,t,r,i,k,a){
            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
          })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=106842347', 'ym');
          ym(106842347, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadMetrika, { timeout: 3000 });
        } else {
          setTimeout(loadMetrika, 2000);
        }
      })();
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/106842347" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

    <!-- Google Analytics (gtag.js) — deferred to not block rendering -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <script is:inline>
      // Track ViewTransitions page navigations for GA
      document.addEventListener('astro:page-load', function() {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'page_view', { page_location: location.href });
        }
      });
      // Defer GA loading until browser is idle
      // ru.chemistry.online → G-79E3NBFSM0, chemistry.online → G-HM75CEBJL9
      (function(){
        function loadGA() {
          var host = location.hostname;
          var gaId = host === 'ru.chemistry.online' ? 'G-79E3NBFSM0' : 'G-HM75CEBJL9';
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaId);
        }
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadGA, { timeout: 3000 });
        } else {
          setTimeout(loadGA, 2000);
        }
      })();
    </script>
    <!-- /Google Analytics -->

    <!-- Ctrl+K / Cmd+K → search -->
    <script is:inline define:vars={{ searchUrl }}>
      document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          if (!location.pathname.includes('search') && !location.pathname.includes('szukaj') && !location.pathname.includes('buscar')) {
            location.href = searchUrl;
          }
        }
      });
    </script>

    <!-- Set Paraglide locale for client-side React islands -->
    <script is:inline define:vars={{ locale }}>
      document.cookie = 'PARAGLIDE_LOCALE=' + locale + ';path=/;max-age=34560000;SameSite=Lax';
    </script>

    <!-- Redirect from old domain to new domain -->
    <script is:inline>
      if (location.hostname === 'chemistry.svistunov.online') {
        location.replace('https://ru.chemistry.online' + location.pathname + location.search + location.hash);
      }
    </script>

    <!-- Service Worker registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>

    <!-- Background precache trigger (connection-aware, SW guards against duplicates) -->
    <script>
      import { initPrecache } from '../lib/offline-precache';
      const locale = document.cookie.match(/PARAGLIDE_LOCALE=(\w+)/)?.[1] || 'ru';
      initPrecache(locale);
    </script>

    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />

    <slot name="head" />
  </head>
  <body>
    <Nav locale={locale} alternateUrls={alternateUrls} />
    <main class="container">
      <slot />
    </main>
    <slot name="after-main" />
    <footer class="site-footer">
      <a href={localizeUrl('/about/', locale)}>{m.footer_about()}</a>
      <span class="site-footer__sep">&middot;</span>
      <a href="https://github.com/dronsv/chemistry-no-magic/issues" target="_blank" rel="noopener noreferrer">{m.footer_bug_report()}</a>
    </footer>
    <OfflineToast client:idle />
  </body>
</html>
