---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import PeriodicTablePage from '../../../features/periodic-table/PeriodicTablePage';
import type { SupportedLocale } from '../../../types/i18n';
const locale = (Astro.currentLocale ?? 'pl') as SupportedLocale;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<BaseLayout title="Układ okresowy" description="Interaktywny układ okresowy: konfiguracje elektronowe, diagramy orbitalne, poziomy energetyczne.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "Układ okresowy — dane o 118 pierwiastkach chemicznych",
      "description": "Dane o 118 pierwiastkach chemicznych: właściwości, konfiguracje elektronowe, stopnie utlenienia, elektroujemność",
      "url": `${siteUrl}/pl/tablica-okresowa/`,
      "creator": { "@type": "Organization", "name": "Chemia bez magii", "url": siteUrl },
      "inLanguage": ["ru", "en", "pl", "es"],
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/",
    })} />
  </Fragment>
  <HubLead section="periodic-table" locale={locale} />
  <PeriodicTablePage locale={locale} client:idle />
</BaseLayout>
