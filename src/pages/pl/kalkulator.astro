---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SolverPage from '../../features/solver/SolverPage';
import type { SupportedLocale } from '../../types/i18n';

const locale = (Astro.currentLocale ?? 'pl') as SupportedLocale;
---

<BaseLayout title="Kalkulator zadań" description="Interaktywny kalkulator zadań chemicznych z wyprowadzeniem krok po kroku. Mieszanie roztworów kwasów i zasad, określanie środowiska i koloru wskaźnika.">
  <SolverPage locale={locale} client:idle />
</BaseLayout>
