---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import TopicLinks from '../../../components/TopicLinks.astro';
import BondsPage from '../../../features/bonds/BondsPage';
import type { SupportedLocale } from '../../../types/i18n';
const locale = (Astro.currentLocale ?? 'pl') as SupportedLocale;
---

<BaseLayout title="Wiązania chemiczne" description="Określanie typów wiązań chemicznych i sieci krystalicznych. Kalkulator, teoria i ćwiczenia.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Wiązania chemiczne i sieci krystaliczne",
      "description": "Określanie typów wiązań chemicznych i sieci krystalicznych na podstawie wzoru substancji. Kalkulator, teoria i ćwiczenia.",
      "provider": { "@type": "Organization", "name": "Chemia bez magii", "url": "https://chemistry.svistunov.online" },
      "educationalLevel": "Klasa 9–11",
      "inLanguage": "pl",
      "teaches": ["wiązanie kowalencyjne", "wiązanie jonowe", "wiązanie metaliczne", "wiązanie wodorowe", "sieci krystaliczne"],
      "availableLanguage": ["ru", "en", "pl", "es"],
      "url": "https://chemistry.svistunov.online/pl/wiazania/",
      "isAccessibleForFree": true,
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Jak określić typ wiązania chemicznego na podstawie wzoru?",
          "acceptedAnswer": { "@type": "Answer", "text": "Wyznacz elektroujemność (EU) każdego pierwiastka. Różnica ΔEU: &lt;0,5 — kowalencyjne niepolarne, 0,5–1,7 — kowalencyjne polarne, &gt;1,7 — jonowe. Metal + niemetal → jonowe; dwa metale → wiązanie metaliczne." }
        },
        {
          "@type": "Question",
          "name": "Jak korzystać z kalkulatora wiązań chemicznych?",
          "acceptedAnswer": { "@type": "Answer", "text": "Wpisz wzór chemiczny substancji w pole wyszukiwania. Kalkulator automatycznie określi typ wiązania i sieci krystalicznej, pokaże elektroujemności pierwiastków i różnicę ΔEU z wyjaśnieniem krok po kroku." }
        },
        {
          "@type": "Question",
          "name": "Jaka jest różnica między wiązaniem jonowym a kowalencyjnym?",
          "acceptedAnswer": { "@type": "Answer", "text": "Wiązanie jonowe: całkowite przekazanie elektronów od metalu do niemetalu (NaCl, KBr). Kowalencyjne: wspólne pary elektronowe między niemetalami. Polarne: różne EU (HCl, H₂O). Niepolarne: jednakowe EU (H₂, O₂, Cl₂)." }
        },
        {
          "@type": "Question",
          "name": "Co to jest sieć krystaliczna i jak wpływa na właściwości?",
          "acceptedAnswer": { "@type": "Answer", "text": "Jonowa (sole): wysoka temperatura topnienia, kruchość, przewodnictwo w roztworze. Atomowa (diament, SiO₂): bardzo wysoka tw, twardość. Cząsteczkowa (lód, CO₂): niska tw, lotność. Metaliczna: przewodnictwo cieplne i elektryczne, plastyczność." }
        }
      ]
    })} />
  </Fragment>
  <HubLead section="bonds" locale={locale} />
  <TopicLinks section="bonds" locale={locale} />
  <BondsPage locale={locale} client:idle />
</BaseLayout>
