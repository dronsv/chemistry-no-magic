  <div class="intl-footer">
    <p>Free &amp; open source &middot; <a href="https://github.com/dronsv/chemistry-no-magic">GitHub</a></p>
  </div>

  <noscript>
    <div class="noscript-box">
      <p>This site requires JavaScript for interactive features.</p>
      <div class="noscript-links">
        <a href="/ru/">Русский</a>
        <a href="/en/">English</a>
        <a href="/pl/">Polski</a>
        <a href="/es/">Español</a>
      </div>
    </div>
  </noscript>

  <script is:inline>
    (function() {
      var langs = navigator.languages || [navigator.language || ''];
      var map = { ru: 'ru', en: 'en', pl: 'pl', es: 'es' };
      var detected = null;
      for (var i = 0; i < langs.length; i++) {
        var code = langs[i].toLowerCase().split('-')[0];
        if (map[code]) { detected = map[code]; break; }
      }
      if (detected) {
        var card = document.querySelector('.lang-card[data-locale="' + detected + '"]');
        if (card) card.classList.add('lang-card--detected');
      }
      var cards = document.querySelectorAll('.lang-card');
      for (var j = 0; j < cards.length; j++) {
        cards[j].addEventListener('click', function() {
          try { localStorage.setItem('preferred_locale', this.getAttribute('data-locale')); } catch(e) {}
        });
      }
    })();
  </script>

  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>

</body>
</html>

<style>
  :root {
    --color-primary: #2563eb;
    --color-bg: #ffffff;
    --color-bg-alt: #f8f9fa;
    --color-text: #1a1a2e;
    --color-text-muted: #6b7280;
    --color-border: #e5e7eb;
    --font-sans: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --color-acid: #fca5a5;
    --color-base: #93c5fd;
    --color-salt: #86efac;
    --color-oxide: #fde68a;
    --color-simple: #c4b5fd;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html { font-family: var(--font-sans); line-height: 1.6; color: var(--color-text); }
  body { margin: 0; background: var(--color-bg); }
  a { color: var(--color-primary); text-decoration: none; }

  .intl-hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 700px; margin: 0 auto; }
  .intl-hero__flask { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .intl-hero h1 { font-size: 2rem; font-weight: 700; margin: 0 0 0.75rem; line-height: 1.2; }
  .intl-hero__sub { font-size: 1.05rem; color: var(--color-text-muted); margin: 0; }

  .intl-stats { display: flex; justify-content: center; gap: 2rem; padding: 1.25rem 1rem; flex-wrap: wrap; }
  .intl-stat { display: flex; flex-direction: column; align-items: center; gap: 0.125rem; }
  .intl-stat__num { font-size: 1.5rem; font-weight: 700; color: var(--color-primary); }
  .intl-stat__label { font-size: 0.75rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.04em; }

  .intl-langs { max-width: 900px; margin: 1.5rem auto 0; padding: 0 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .lang-card {
    display: block; background: var(--color-bg-alt); border: 2px solid var(--color-border);
    border-radius: 0.75rem; padding: 1.25rem 1.5rem; color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; overflow: hidden;
  }
  .lang-card:hover { text-decoration: none; border-color: var(--color-primary); box-shadow: 0 4px 16px rgba(37,99,235,0.12); transform: translateY(-2px); }
  .lang-card--detected { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }

  .lang-card__name { font-size: 1.25rem; font-weight: 700; margin: 0 0 0.25rem; }
  .lang-card__topics { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0 0 0.5rem; }
  .lang-card__exams { font-size: 0.75rem; color: var(--color-primary); font-weight: 600; margin: 0 0 0.75rem; }

  .formula-strip {
    display: flex; gap: 0.5rem; overflow: hidden; margin: 0 -1.5rem; padding: 0.375rem 0;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .formula-track { display: flex; gap: 0.5rem; animation: scroll-formulas 25s linear infinite; flex-shrink: 0; }
  .formula-track[data-speed="slow"] { animation-duration: 35s; }
  .formula-track[data-speed="fast"] { animation-duration: 20s; }
  @keyframes scroll-formulas { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .f-chip { display: inline-block; padding: 0.2rem 0.55rem; border-radius: 0.35rem; font-size: 0.75rem; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
  .f-chip--acid { background: var(--color-acid); color: #991b1b; }
  .f-chip--base { background: var(--color-base); color: #1e40af; }
  .f-chip--salt { background: var(--color-salt); color: #166534; }
  .f-chip--oxide { background: var(--color-oxide); color: #92400e; }
  .f-chip--simple { background: var(--color-simple); color: #5b21b6; }

  .intl-footer { text-align: center; padding: 2.5rem 1rem 2rem; font-size: 0.8125rem; color: var(--color-text-muted); }
  .intl-footer a { color: var(--color-primary); }

  .noscript-box { max-width: 600px; margin: 2rem auto; padding: 1rem 1.5rem; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 0.5rem; text-align: center; font-size: 0.9rem; }
  .noscript-links { display: flex; justify-content: center; gap: 1.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
  .noscript-links a { font-weight: 600; font-size: 1rem; }

  @media (max-width: 600px) { .intl-hero h1 { font-size: 1.5rem; } .intl-langs { grid-template-columns: 1fr; } .intl-stats { gap: 1.25rem; } }
  @media (prefers-reduced-motion: reduce) { .formula-track { animation: none; } }
</style>
