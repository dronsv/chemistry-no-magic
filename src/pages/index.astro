---
/**
 * International landing page — language selection with formula carousels.
 * No BaseLayout (no nav, no footer) — standalone page.
 */
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Chemistry Without Magic — Interactive Chemistry Learning Platform</title>
  <meta name="description" content="Free interactive chemistry platform: periodic table, substances, reactions, calculations, and exam preparation. Available in Russian, English, Polish, Spanish.">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">
  <meta name="theme-color" content="#2563eb">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="robots" content="index, follow">

  <link rel="canonical" href={`${siteUrl}/`}>

  <link rel="alternate" hreflang="ru-RU" href={`${siteUrl}/ru/`}>
  <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`}>
  <link rel="alternate" hreflang="pl" href={`${siteUrl}/pl/`}>
  <link rel="alternate" hreflang="es" href={`${siteUrl}/es/`}>
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`}>

  <meta property="og:title" content="Chemistry Without Magic — Interactive Chemistry Learning Platform">
  <meta property="og:description" content="Free interactive chemistry platform with 118 elements, 5 exam systems, and 4 languages.">
  <meta property="og:type" content="website">
  <meta property="og:url" content={`${siteUrl}/`}>
  <meta property="og:site_name" content="Chemistry Without Magic">
  <meta property="og:image" content={`${siteUrl}/og-default.png`}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Chemistry Without Magic — Interactive Chemistry Learning Platform">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Chemistry Without Magic — Interactive Chemistry Learning Platform">
  <meta name="twitter:description" content="Free interactive chemistry platform with 118 elements, 5 exam systems, and 4 languages.">
  <meta name="twitter:image" content={`${siteUrl}/og-default.png`}>
  <meta name="twitter:image:alt" content="Chemistry Without Magic — Interactive Chemistry Learning Platform">

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Chemistry Without Magic",
    "alternateName": "Химия без магии",
    "url": siteUrl,
    "description": "Free interactive chemistry platform: periodic table, substances, reactions, calculations, and exam preparation.",
    "inLanguage": ["ru", "en", "pl", "es"],
    "publisher": {
      "@type": "Organization",
      "name": "Chemistry Without Magic",
      "logo": `${siteUrl}/icons/icon-512.png`,
      "sameAs": ["https://github.com/dronsv/chemistry-no-magic"],
    }
  })} />

  <!-- Analytics (deferred) -->
  <link rel="dns-prefetch" href="https://mc.yandex.ru">
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <script is:inline>
    (function(){
      function loadMetrika() {
        (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
        })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=106842347', 'ym');
        ym(106842347, 'init', {clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true});
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadMetrika, { timeout: 3000 });
      } else {
        setTimeout(loadMetrika, 2000);
      }
    })();
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/106842347" style="position:absolute; left:-9999px;" alt=""></div></noscript>
  <script is:inline>
    (function(){
      function loadGA() {
        var host = location.hostname;
        var gaId = host === 'ru.chemistry.online' ? 'G-79E3NBFSM0' : 'G-HM75CEBJL9';
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGA, { timeout: 3000 });
      } else {
        setTimeout(loadGA, 2000);
      }
    })();
  </script>

  <script is:inline>
    // Early redirect: if user has a saved language preference, go straight there
    (function() {
      try {
        var loc = localStorage.getItem('preferred_locale');
        if (loc && /^(ru|en|pl|es)$/.test(loc)) {
          location.replace('/' + loc + '/');
        }
      } catch(e) {}
    })();
  </script>

  <script is:inline>
    if (location.hostname === 'chemistry.svistunov.online') {
      location.replace('https://ru.chemistry.online' + location.pathname + location.search + location.hash);
    }
  </script>
</head>
<body>

