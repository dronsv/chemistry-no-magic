          <span class="f-chip f-chip--base">NaOH</span>
          <span class="f-chip f-chip--salt">NaCl</span>
          <span class="f-chip f-chip--oxide">Fe₂O₃</span>
          <span class="f-chip f-chip--acid">HNO₃</span>
          <span class="f-chip f-chip--base">Ca(OH)₂</span>
          <span class="f-chip f-chip--salt">CaCO₃</span>
          <span class="f-chip f-chip--oxide">CuO</span>
          <span class="f-chip f-chip--simple">O₂</span>
          <span class="f-chip f-chip--acid">HCl</span>
          <span class="f-chip f-chip--salt">KMnO₄</span>
          <span class="f-chip f-chip--base">KOH</span>
