---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicalFoundationsPage from '../../features/physical-foundations/PhysicalFoundationsPage';
import type { SupportedLocale } from '../../types/i18n';
const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;
---

<BaseLayout
  title="Физические основы химии"
  description="Объяснения ключевых физических понятий, механизмов и мостов между физикой и химией: температура, тепловое движение, энергетические уровни, обменная стабилизация."
  lang="ru"
>
  <PhysicalFoundationsPage locale={locale} client:idle />
</BaseLayout>
