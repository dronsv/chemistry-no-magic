---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import TopicLinks from '../../../components/TopicLinks.astro';
import BondsPage from '../../../features/bonds/BondsPage';
import type { SupportedLocale } from '../../../types/i18n';
const locale = (Astro.currentLocale ?? 'es') as SupportedLocale;
---

<BaseLayout title="Enlaces químicos" description="Determinación de tipos de enlaces químicos y redes cristalinas. Calculadora, teoría y práctica.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Enlaces químicos y redes cristalinas",
      "description": "Determinación de tipos de enlaces químicos y redes cristalinas a partir de la fórmula de la sustancia. Calculadora, teoría y práctica.",
      "provider": { "@type": "Organization", "name": "Química sin magia", "url": "https://chemistry.svistunov.online" },
      "educationalLevel": "Curso 9–11",
      "inLanguage": "es",
      "teaches": ["enlace covalente", "enlace iónico", "enlace metálico", "enlace de hidrógeno", "redes cristalinas"],
      "availableLanguage": ["ru", "en", "pl", "es"],
      "url": "https://chemistry.svistunov.online/es/enlaces/",
      "isAccessibleForFree": true,
    })} />
  </Fragment>
  <HubLead section="bonds" locale={locale} />
  <TopicLinks section="bonds" locale={locale} />
  <BondsPage locale={locale} client:idle />
</BaseLayout>
