---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import PeriodicTablePage from '../../../features/periodic-table/PeriodicTablePage';
import type { SupportedLocale } from '../../../types/i18n';
const locale = (Astro.currentLocale ?? 'es') as SupportedLocale;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<BaseLayout title="Tabla periódica" description="Tabla periódica interactiva: configuraciones electrónicas, diagramas orbitales, niveles de energía.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "Tabla periódica — datos de 118 elementos químicos",
      "description": "Datos sobre 118 elementos químicos: propiedades, configuraciones electrónicas, estados de oxidación, electronegatividad",
      "url": `${siteUrl}/es/tabla-periodica/`,
      "creator": { "@type": "Organization", "name": "Química sin magia", "url": siteUrl },
      "inLanguage": ["ru", "en", "pl", "es"],
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/",
    })} />
  </Fragment>
  <HubLead section="periodic-table" locale={locale} />
  <PeriodicTablePage locale={locale} client:idle />
</BaseLayout>
