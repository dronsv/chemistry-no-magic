---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SimpleSubstancesPage from '../../features/simple-substances/SimpleSubstancesPage';
import type { SupportedLocale } from '../../types/i18n';

const locale = (Astro.currentLocale ?? 'es') as SupportedLocale;
---

