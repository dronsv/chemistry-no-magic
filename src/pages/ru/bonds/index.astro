---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import BondsPage from '../../../features/bonds/BondsPage';
import TopicLinks from '../../../components/TopicLinks.astro';
import type { SupportedLocale } from '../../../types/i18n';

const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<BaseLayout title="Химическая связь" description="Определение типа химической связи и кристаллической решётки по формуле вещества. Калькулятор, теория и практика для ОГЭ.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Химическая связь",
      "description": "Определение типа химической связи и кристаллической решётки по формуле вещества",
      "educationalLevel": "9 класс",
      "inLanguage": "ru",
      "teaches": ["ионная связь", "ковалентная полярная связь", "ковалентная неполярная связь", "металлическая связь", "кристаллические решётки"],
      "isPartOf": { "@type": "WebSite", "name": "Химия без магии", "url": Astro.site?.toString() ?? Astro.url.origin },
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Химические связи и кристаллические решётки",
      "description": "Определение типа химической связи и кристаллической решётки по формуле вещества. Калькулятор с пошаговым объяснением, теория и практика для ОГЭ.",
      "provider": { "@type": "Organization", "name": "Химия без магии", "url": siteUrl },
      "educationalLevel": "9–11 класс",
      "inLanguage": "ru",
      "teaches": ["ковалентная связь", "ионная связь", "металлическая связь", "водородная связь", "кристаллические решётки"],
      "availableLanguage": ["ru", "en", "pl", "es"],
      "url": `${siteUrl}/bonds/`,
      "isAccessibleForFree": true,
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Как определить тип химической связи по формуле?",
          "acceptedAnswer": { "@type": "Answer", "text": "Определите электроотрицательность (ЭО) каждого элемента. Разность ΔЭО: &lt;0.5 — ковалентная неполярная, 0.5–1.7 — ковалентная полярная, &gt;1.7 — ионная. Металл + неметалл → ионная; два металла → металлическая." }
        },
        {
          "@type": "Question",
          "name": "Как пользоваться калькулятором химической связи?",
          "acceptedAnswer": { "@type": "Answer", "text": "Введите химическую формулу вещества в поле ввода. Калькулятор автоматически определит тип связи и кристаллической решётки, покажет электроотрицательности элементов и разность ΔЭО с пошаговым объяснением." }
        },
        {
          "@type": "Question",
          "name": "В чём разница между ионной и ковалентной связью?",
          "acceptedAnswer": { "@type": "Answer", "text": "Ионная связь — полная передача электронов от металла к неметаллу (NaCl, KBr). Ковалентная — общие электронные пары между неметаллами. Полярная ковалентная: ЭО разные (HCl, H₂O). Неполярная: ЭО одинаковые (H₂, O₂, Cl₂)." }
        },
        {
          "@type": "Question",
          "name": "Что такое кристаллическая решётка и как она влияет на свойства?",
          "acceptedAnswer": { "@type": "Answer", "text": "Ионная решётка (соли) — высокая температура плавления, хрупкость, электропроводность в растворе. Атомная (алмаз, SiO₂) — очень высокая тпл, твёрдость. Молекулярная (лёд, CO₂) — низкая тпл, летучесть. Металлическая — тепло- и электропроводность, пластичность." }
        }
      ]
    })} />
  </Fragment>
  <HubLead section="bonds" locale={locale} />
  <TopicLinks section="bonds" locale={locale} />
  <BondsPage locale={locale} client:idle />
</BaseLayout>
