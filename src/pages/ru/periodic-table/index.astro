---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubLead from '../../../components/HubLead.astro';
import PeriodicTablePage from '../../../features/periodic-table/PeriodicTablePage';
import ElementQuicklinks from '../../../components/ElementQuicklinks';
import type { SupportedLocale } from '../../../types/i18n';
import { localizeUrl } from '../../../lib/i18n';

const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<BaseLayout title="Периодическая таблица" description="Интерактивная периодическая таблица Менделеева: электронные конфигурации, орбитальные диаграммы, энергетические уровни и практика.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": "Интерактивная периодическая таблица Менделеева",
      "description": "Периодическая таблица с электронными конфигурациями, орбитальными диаграммами и упражнениями для подготовки к ОГЭ.",
      "educationalLevel": "ОГЭ (9 класс)",
      "learningResourceType": "Interactive resource",
      "inLanguage": "ru",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Химия без магии",
        "url": Astro.site?.toString(),
      },
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "Таблица Менделеева — данные о 118 химических элементах",
      "description": "Машиночитаемые данные о 118 химических элементах: свойства, электронные конфигурации, степени окисления, электроотрицательность",
      "url": `${siteUrl}/periodic-table/`,
      "creator": { "@type": "Organization", "name": "Химия без магии", "url": siteUrl },
      "inLanguage": ["ru", "en", "pl", "es"],
      "isAccessibleForFree": true,
      "license": "https://creativecommons.org/licenses/by/4.0/",
    })} />
  </Fragment>
  <HubLead section="periodic-table" locale={locale} />
  <ElementQuicklinks
    elements={["el:H", "el:O", "el:C", "el:N", "el:Na", "el:Cl", "el:Fe", "el:Cu", "el:Ca", "el:Al", "el:Au", "el:Si", "el:P", "el:S"]}
    locale={locale}
    client:idle
  />
  <PeriodicTablePage locale={locale} client:idle />
</BaseLayout>

<style>
  .pt-quicklinks {
    padding: 0.75rem 0 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.5rem;
  }
  .pt-quicklinks__label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0 0 0.4rem;
    font-weight: 500;
  }
  .pt-quicklinks__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .pt-quicklinks__item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 0.3rem;
    font-size: 0.8125rem;
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-bg-alt);
    transition: border-color 0.12s;
  }
  .pt-quicklinks__item:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }
  .pt-quicklinks__sym { font-weight: 700; }
  .pt-quicklinks__name { color: var(--color-text-muted); font-size: 0.75rem; }
</style>
