---
/**
 * Static topic navigation chips for hub pages (bonds, oxidation-states, calculations).
 * Renders build-time links to topic detail pages — visible to crawlers without JS.
 */
import { cachedReadDataSrcSync, cachedReadJsonSync } from '../lib/build-data-cache';
import { join } from 'node:path';
import type { Topic, TopicLocaleOverlay } from '../types/topic';
import type { SupportedLocale } from '../types/i18n';
import { localizeUrl } from '../lib/i18n';

interface Props {
  section: string;
  locale: SupportedLocale;
  heading?: string;
}

const { section, locale, heading } = Astro.props;
const topics: Topic[] = cachedReadDataSrcSync('topics.json');
const sectionTopics = topics.filter(t => t.section === section);
if (sectionTopics.length === 0) return;

let overlay: TopicLocaleOverlay | null = null;
if (locale !== 'ru') {
  try {
    overlay = cachedReadJsonSync<TopicLocaleOverlay>(
      join(process.cwd(), 'data-src', 'translations', locale, 'topics.json'),
    );
  } catch { /* no overlay */ }
}

const sectionUrl = localizeUrl(`/${section}/`, locale);
const items = sectionTopics.map(topic => {
  const lf = overlay?.[topic.id];
  return {
    href: `${sectionUrl}${lf?.slug ?? topic.slug}/`,
    title: lf?.title ?? topic.title_ru,
  };
});

const HEADINGS: Record<SupportedLocale, string> = {
  ru: 'По темам', en: 'Topics', pl: 'Tematy', es: 'Temas',
};
const label = heading ?? HEADINGS[locale];
---

<nav class="topic-links" aria-label={label}>
  <span class="topic-links-label">{label}:</span>
  {items.map(item => (
    <a href={item.href} class="topic-chip">{item.title}</a>
  ))}
</nav>

<style>
  .topic-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--surface-alt, #f9fafb);
    border-radius: 0.5rem;
    margin: 0.75rem 0 0;
  }

  .topic-links-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .topic-chip {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: #fff;
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 2rem;
    color: var(--color-primary, #2563eb);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }

  .topic-chip:hover {
    background: var(--color-primary, #2563eb);
    border-color: var(--color-primary, #2563eb);
    color: #fff;
  }
</style>
