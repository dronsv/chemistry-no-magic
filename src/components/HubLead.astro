const content = HUB_DATA[section][locale];
---

<header class="hub-lead">
  <h1 class="hub-lead__h1">{content.h1}</h1>
  <p class="hub-lead__def" set:html={content.def} />
  <p class="hub-lead__scope" set:html={content.scope} />
  {content.properties && content.properties.length > 0 && (
    <div class="hub-props">
      {content.properties.map(group => (
        <div class="hub-props__group">
          <span class="hub-props__label">{group.label}:</span>
          <span class="hub-props__items" set:html={group.items.join(' · ')} />
        </div>
      ))}
    </div>
  )}
  {content.details && content.details.length > 0 && (
    <div class="hub-details">
      {content.details.map(block => (
        <div class="hub-details__block">
          <h2 class="hub-details__heading">{block.heading}</h2>
          <dl class="hub-details__dl">
            {block.items.map(item => (
              <>
                <dt class="hub-details__term">{item.term}</dt>
                <dd class="hub-details__def" set:html={item.def} />
              </>
            ))}
          </dl>
          {block.mnemonic && (
            <p class="hub-details__mnemonic" set:html={block.mnemonic} />
          )}
        </div>
      ))}
    </div>
  )}
  {content.facets && content.facets.length > 0 && (
    <div class="hub-facets">
      {content.facets.map(f =>
        typeof f === 'string'
          ? <span class="hub-facet">{f}</span>
          : <a class="hub-facet hub-facet--link" href={f.href}>{f.label}</a>
      )}
    </div>
  )}
</header>

<style>
  .hub-lead {
    padding: 1.5rem 0 1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }
  .hub-lead__h1 {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }
  .hub-lead__def {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0 0 0.375rem;
    font-weight: 500;
  }
  .hub-lead__scope {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }
  .hub-lead__def :global(a),
  .hub-lead__scope :global(a),
  .hub-props :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: rgba(37, 99, 235, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s;
  }
  .hub-lead__def :global(a:hover),
  .hub-lead__scope :global(a:hover),
  .hub-props :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }
  .hub-props {
    margin-top: 0.625rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .hub-props__group {
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .hub-props__label {
    font-weight: 600;
    color: var(--color-text);
  }
  .hub-props__items {
    color: var(--color-text-muted);
  }
  .hub-details {
    margin-top: 0.75rem;
  }
  .hub-details__heading {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.375rem;
    line-height: 1.4;
  }
  .hub-details__dl {
    margin: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.125rem 0.5rem;
  }
  .hub-details__term {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    white-space: nowrap;
  }
  .hub-details__term::after {
    content: '\00a0—';
    font-weight: 400;
  }
  .hub-details__def {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }
  .hub-details__def :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
  .hub-details__def :global(em) {
    font-style: italic;
    color: var(--color-text);
  }
  .hub-details__mnemonic {
