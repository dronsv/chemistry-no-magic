---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormulaChip from '../../components/FormulaChip.tsx';
import ContextBackLink from '../../components/ContextBackLink.tsx';
import type { SupportedLocale } from '../../types/i18n';
import { localizeUrl } from '../../lib/i18n';
import { loadBuildOverlay, applyBuildOverlay } from '../../lib/build-overlay';
import { cachedReadDataSrc } from '../../lib/build-data-cache';
import type { StorageRequirement, StorageProfile } from '../../types/storage';
import type { Props } from './element-detail-paths';
import * as m from '../../paraglide/messages.js';

const { element, elementReactions, relatedSubstances, groupLabel: baseGroupLabel, elementIons, qualitativeTests } = Astro.props as Props;
const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;

// Apply locale overlays
const el = { ...element };
const elementsOverlay = await loadBuildOverlay(locale, 'elements');
if (elementsOverlay && elementsOverlay[el.symbol]) {
  const ov = { ...elementsOverlay[el.symbol] };
  if (ov.discovery && el.discovery) {
    el.discovery = { ...el.discovery, ...(ov.discovery as typeof el.discovery) };
    delete ov.discovery;
  }
  Object.assign(el, ov);
}

// Apply element-groups overlay for groupLabel
let groupLabel = baseGroupLabel;
const groupsOverlay = await loadBuildOverlay(locale, 'element_groups');
if (groupsOverlay && groupsOverlay[el.element_group]?.name_singular_ru) {
  groupLabel = groupsOverlay[el.element_group].name_singular_ru as string;
}

// Apply reactions overlay for titles
const reactionsOverlay = await loadBuildOverlay(locale, 'reactions');
const localizedReactions = elementReactions.map(r => {
  if (reactionsOverlay && reactionsOverlay[r.reaction_id]?.title) {
    return { ...r, title: reactionsOverlay[r.reaction_id].title as string };
  }
  return r;
});

// Apply ions overlay for names
const ionsOverlay = await loadBuildOverlay(locale, 'ions');
const localizedIons = elementIons.map(ion => {
  if (ionsOverlay && ionsOverlay[ion.id]?.name_ru) {
    return { ...ion, name_ru: ionsOverlay[ion.id].name_ru as string };
  }
  return ion;
});

// Apply substances overlay for names
const substancesOverlay = await loadBuildOverlay(locale, 'substances');
const localizedSubstances = relatedSubstances.map(s => {
  if (substancesOverlay && substancesOverlay[s.id]?.name_ru) {
    return { ...s, name_ru: substancesOverlay[s.id].name_ru as string };
  }
  return s;
});

// Apply qualitative tests overlay
const qualOverlay = await loadBuildOverlay(locale, 'qualitative_reactions');
const localizedTests = qualitativeTests.map(qt => {
  if (qualOverlay && qualOverlay[qt.target_id]) {
    return { ...qt, ...qualOverlay[qt.target_id] };
  }
  return qt;
});

const oxStates = el.typical_oxidation_states
  .map(s => (s > 0 ? `+${s}` : String(s)))
  .join(', ');

const hasPhysical = el.melting_point_C != null || el.boiling_point_C != null || el.density_g_cm3 != null;
const hasDiscovery = el.discovery && (el.discovery.year || el.discovery.scientist_ru);
const hasHazards = el.hazards_ru && el.hazards_ru.length > 0;
const hasFacts = el.fun_facts_ru && el.fun_facts_ru.length > 0;

// Resolve storage profile labels for this element
const storageLabels: string[] = [];
if (el.storage_profiles && el.storage_profiles.length > 0) {
  const [storageReqs, storageProfs] = await Promise.all([
    cachedReadDataSrc<StorageRequirement[]>('storage_requirements.json'),
    cachedReadDataSrc<StorageProfile[]>('storage_profiles.json'),
  ]);
  const reqsById = Object.fromEntries(storageReqs.map(r => [r.id, r]));
  const profsById = Object.fromEntries(storageProfs.map(p => [p.id, p]));
  const reqIds = el.storage_profiles
    .flatMap(pid => profsById[pid]?.requires ?? [])
    .filter((id, i, arr) => arr.indexOf(id) === i);
  for (const rid of reqIds) {
    const label = reqsById[rid]?.labels[locale] ?? reqsById[rid]?.labels.ru;
    if (label) storageLabels.push(label);
  }
}
const hasStorage = storageLabels.length > 0;

// Build names worldwide list (show names in other languages as interesting fact)
const namesList: { lang: string; name: string }[] = [];
// Always show the base Russian name
if (locale !== 'ru') namesList.push({ lang: 'ru', name: element.name_ru });
// Show name_en from base data
if (locale !== 'en' && element.name_en) namesList.push({ lang: 'en', name: element.name_en });
// Show name_latin
if (element.name_latin) namesList.push({ lang: 'la', name: element.name_latin });
// Add overlayed names from other locales (if different from current)
for (const otherLocale of ['en', 'pl', 'es'] as const) {
  if (otherLocale === locale) continue;
  if (otherLocale === 'en') continue; // already handled above from name_en
  const otherOverlay = await loadBuildOverlay(otherLocale, 'elements');
  if (otherOverlay?.[el.symbol]?.name_ru) {
    namesList.push({ lang: otherLocale, name: otherOverlay[el.symbol].name_ru as string });
  }
}

const LANG_FLAGS: Record<string, string> = { ru: 'RU', en: 'EN', la: 'LA', pl: 'PL', es: 'ES' };

const contextBackLabels = {
  exam: m.back_to_exam(),
  practice: m.back_to_practice(),
  diagnostics: m.back_to_diagnostics(),
  previous: m.back_to_previous(),
};
---

<BaseLayout
  title={m.el_title({ name: el.name_ru, symbol: el.symbol, z: String(el.Z) })}
  description={m.el_description({ name: el.name_ru, symbol: el.symbol, z: String(el.Z) })}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ChemicalSubstance",
      "name": el.name_ru,
      "alternateName": el.name_en,
      "description": m.el_jsonld_desc({ name: el.name_ru, z: String(el.Z), group: groupLabel.toLowerCase() }),
      "inLanguage": locale,
    })} />
  </Fragment>

  <ContextBackLink client:idle labels={contextBackLabels} />
  <article class="element-page container">
    <div class="element-page__header">
      <div class="element-page__z">{el.Z}</div>
      <h1 class="element-page__symbol">{el.symbol}</h1>
      <div class="element-page__name">{el.name_ru}</div>
      <div class="element-page__latin">{el.name_latin}</div>
    </div>

    <dl class="element-page__props">
      <dt>{m.el_atomic_mass()}</dt>
      <dd>{el.atomic_mass}</dd>

      <dt>{m.el_group_period()}</dt>
      <dd>{el.group} / {el.period}</dd>

      <dt>{m.el_type()}</dt>
      <dd>{groupLabel}</dd>

      {oxStates && (
        <>
          <dt>{m.el_oxidation_states()}</dt>
          <dd>{oxStates}</dd>
        </>
      )}

      {el.electronegativity != null && (
        <>
          <dt>{m.el_electronegativity()}</dt>
          <dd>{el.electronegativity} {m.el_pauling()}</dd>
        </>
      )}
    </dl>

    {el.electron_exception && (
      <section class="element-page__section element-page__exception">
        <h2>{m.el_electron_exception()}</h2>
        <div class="element-page__exception-compare">
          <span>{m.el_expected_config()} <s>{el.electron_exception.expected_formula}</s></span>
          <span>{m.el_actual_config()} <b>{el.electron_exception.actual_formula}</b></span>
        </div>
        <p class="element-page__text">{el.electron_exception.reason_ru}</p>
      </section>
    )}

    {hasPhysical && (
      <section class="element-page__section">
        <h2>{m.el_physical_properties()}</h2>
        <dl class="element-page__props">
          {el.melting_point_C != null && (
            <>
              <dt>{m.prop_melting()}</dt>
              <dd>{el.melting_point_C} °C</dd>
            </>
          )}
          {el.boiling_point_C != null && (
            <>
              <dt>{m.subst_detail_boiling()}</dt>
              <dd>{el.boiling_point_C} °C</dd>
            </>
          )}
          {el.density_g_cm3 != null && (
            <>
              <dt>{m.el_density()}</dt>
              <dd>{el.density_g_cm3} {m.el_density_unit()}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    {hasDiscovery && (
      <section class="element-page__section">
        <h2>{m.el_discovery()}</h2>
        <div class="element-page__discovery">
          {el.discovery!.year && <span class="element-page__discovery-year">{el.discovery!.year}{m.el_year_suffix() ? ` ${m.el_year_suffix()}` : ''}</span>}
          {el.discovery!.scientist_ru && <span>{el.discovery!.scientist_ru}</span>}
          {el.discovery!.country_ru && <span class="element-page__discovery-country">({el.discovery!.country_ru})</span>}
        </div>
      </section>
    )}

    {el.abundance_ru && (
      <section class="element-page__section">
        <h2>{m.el_abundance()}</h2>
        <p class="element-page__text">{el.abundance_ru}</p>
      </section>
    )}

    {el.industrial_ru && (
      <section class="element-page__section">
        <h2>{m.el_industrial()}</h2>
        <p class="element-page__text">{el.industrial_ru}</p>
      </section>
    )}

    {el.production_ru && (
      <section class="element-page__section">
        <h2>{m.el_production()}</h2>
        <p class="element-page__text">{el.production_ru}</p>
      </section>
    )}

    {(hasHazards || hasStorage) && (
      <section class="element-page__section">
        <h2>{m.el_hazards()}</h2>
        {hasHazards && (
          <div class="element-page__hazards">
            {el.hazards_ru!.map(h => (
              <span class="element-page__hazard-tag">{h}</span>
            ))}
          </div>
        )}
        {hasStorage && (
          <ul class="element-page__storage-list">
            {storageLabels.map(label => (
              <li class="element-page__storage-item">{label}</li>
            ))}
          </ul>
        )}
      </section>
    )}

    {localizedReactions.length > 0 && (
      <section class="element-page__section">
        <h2>{m.el_reactions()}</h2>
        <ul class="element-page__reactions">
          {localizedReactions.map(r => (
            <li>
              <a href={`${localizeUrl('/reactions/', locale)}#${r.reaction_id}`}>{r.equation}</a>
              <span class="element-page__reaction-title">{r.title}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {localizedIons.length > 0 && (
      <section class="element-page__section">
        <h2>{m.el_ions()}</h2>
        <div class="element-page__ions">
          {localizedIons.map(ion => (
            <FormulaChip
              formula={ion.formula}
              name={ion.name_ru}
              ionType={ion.type === 'cation' ? 'cation' : 'anion'}
              ionId={ion.id}
            />
          ))}
        </div>
      </section>
    )}

    {localizedSubstances.length > 0 && (
      <section class="element-page__section">
        <h2>{m.el_substances()}</h2>
        <div class="element-page__substances">
          {localizedSubstances.map(s => (
            <FormulaChip
              formula={s.formula}
              name={s.name_ru}
              substanceId={s.id}
              substanceClass={s.class}
              locale={locale}
            />
          ))}
        </div>
      </section>
    )}

    {localizedTests.length > 0 && (
      <section class="element-page__section">
        <h2>{m.el_qualitative_tests()}</h2>
        <div class="element-page__qual-tests">
          {localizedTests.map(qt => (
            <div class="element-page__qual-test">
              <div class="element-page__qual-target">{qt.target_name_ru}</div>
              <dl class="element-page__qual-props">
                <dt>{m.el_reagent()}</dt>
                <dd>
                  <FormulaChip formula={qt.reagent_formula} name={qt.reagent_name_ru} />
                </dd>
                <dt>{m.el_observation()}</dt>
                <dd>{qt.observation_ru}</dd>
              </dl>
            </div>
          ))}
        </div>
      </section>
    )}

    {hasFacts && (
      <section class="element-page__section">
        <h2>{m.el_fun_facts()}</h2>
        <ul class="element-page__facts">
          {el.fun_facts_ru!.map(f => (
            <li>{f}</li>
          ))}
        </ul>
      </section>
    )}

    {namesList.length > 0 && (
      <section class="element-page__section">
        <h2>{m.el_names_worldwide()}</h2>
        <div class="element-page__names">
          {namesList.map(n => (
            <span class="element-page__name-entry">
              <span class="element-page__name-lang">{LANG_FLAGS[n.lang] ?? n.lang}</span>
              {n.name}
            </span>
          ))}
        </div>
      </section>
    )}

    <div class="element-page__actions">
      <a href={localizeUrl('/periodic-table/', locale)}>&larr; {m.el_back_table()}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .element-page {
    max-width: 640px;
    padding: var(--space-xl) var(--space-md);
  }

  .element-page__header {
    text-align: center;
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-bg-alt);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
  }
  .element-page__z {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .element-page__symbol {
    font-size: 3rem;
    margin: 0;
    line-height: 1.1;
  }
  .element-page__name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-xs);
  }
  .element-page__latin {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .element-page__props {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm) var(--space-lg);
    margin-bottom: var(--space-lg);
    align-items: baseline;
  }
  .element-page__props dt {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
  .element-page__props dd {
    margin: 0;
    font-size: 0.9375rem;
  }

  .element-page__section {
    margin-bottom: var(--space-xl);
  }
  .element-page__section h2 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-border);
  }

  .element-page__text {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    color: var(--color-text);
  }

  .element-page__exception {
    padding: var(--space-md);
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 0.5rem;
  }
  .element-page__exception-compare {
    display: flex;
    gap: var(--space-lg);
    font-size: 0.9375rem;
    font-family: var(--font-mono);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .element-page__discovery {
    display: flex;
    gap: var(--space-sm);
    align-items: baseline;
    font-size: 0.9375rem;
    flex-wrap: wrap;
  }
  .element-page__discovery-year {
    font-weight: 700;
    color: var(--color-primary);
  }
  .element-page__discovery-country {
    color: var(--color-text-muted);
  }

  .element-page__hazards {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }
  .element-page__hazard-tag {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    font-size: 0.8125rem;
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
    border-radius: 0.25rem;
    font-weight: 500;
  }
  .element-page__storage-list {
    margin-top: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border-left: 3px solid #f59e0b;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .element-page__storage-item::before {
    content: '→ ';
    color: #f59e0b;
    font-weight: 600;
  }

  .element-page__reactions {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .element-page__reactions li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .element-page__reactions li:last-child {
    border-bottom: none;
  }
  .element-page__reactions a {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  .element-page__reaction-title {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .element-page__ions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .element-page__substances {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .element-page__qual-tests {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .element-page__qual-test {
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }
  .element-page__qual-target {
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: var(--space-xs);
  }
  .element-page__qual-props {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-md);
    font-size: 0.875rem;
    align-items: baseline;
  }
  .element-page__qual-props dt {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }
  .element-page__qual-props dd {
    margin: 0;
  }

  .element-page__names {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .element-page__name-entry {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }
  .element-page__name-lang {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .element-page__facts {
    margin: 0;
    padding-left: var(--space-lg);
  }
  .element-page__facts li {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: var(--space-xs);
  }

  .element-page__actions {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
</style>
