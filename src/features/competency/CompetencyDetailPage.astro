---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompetencyMasteryIsland from '../../features/profile/CompetencyMasteryIsland';
import CompetencyPracticeIsland from '../../features/competency/CompetencyPracticeIsland';
import ChainsContent from '../../components/competency-content/ChainsContent.astro';
import QualTestsContent from '../../components/competency-content/QualTestsContent.astro';
import RateContent from '../../components/competency-content/RateContent.astro';
import CatalystContent from '../../components/competency-content/CatalystContent.astro';
import ExchangeContent from '../../components/competency-content/ExchangeContent.astro';
import ClassRulesContent from '../../components/competency-content/ClassRulesContent.astro';
import NamingContent from '../../components/competency-content/NamingContent.astro';
import SolubilityTable from '../../features/reactions/SolubilityTable';
import type { SupportedLocale } from '../../types/i18n';
import { localizeUrl, SITE_NAME } from '../../lib/i18n';
import { loadBuildOverlay } from '../../lib/build-overlay';
import { cachedReadDerived } from '../../lib/build-data-cache';
import * as m from '../../paraglide/messages.js';
import type { Props } from './competency-detail-paths';

const { competency: baseCompetency, prereqs: basePrereqs, unlocks: baseUnlocks, contentProps } = Astro.props as Props;
const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;
const siteName = SITE_NAME[locale];
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Apply locale overlays for competency data
const compOverlay = await loadBuildOverlay(locale, 'competencies');
const applyCompOverlay = <T extends Record<string, unknown>>(item: T, id: string): T => {
  if (compOverlay && compOverlay[id]) return { ...item, ...compOverlay[id] } as T;
  return item;
};
const competency = applyCompOverlay(baseCompetency, baseCompetency.id);
const prereqs = basePrereqs.map(p => applyCompOverlay(p, p.id));
const unlocks = baseUnlocks.map(u => applyCompOverlay(u, u.id));
const cid = competency.id;

// ── Apply locale overlays to content data ────────────────────────
/** Shallow-merge overlay fields into each array item, keyed by `keyField`. */
function applyArrayOverlay<T extends Record<string, unknown>>(
  items: T[],
  overlay: Record<string, Record<string, unknown>> | null,
  keyField: string,
): T[] {
  if (!overlay) return items;
  return items.map(item => {
    const key = item[keyField] as string;
    const patch = overlay[key];
    return patch ? { ...item, ...patch } as T : item;
  });
}

/** Deep-merge energy_catalyst_theory overlay. */
function applyEnergyOverlay(
  theory: Record<string, unknown>,
  overlay: Record<string, Record<string, unknown>> | null,
): Record<string, unknown> {
  if (!overlay) return theory;
  const result = { ...theory };
  // rate_factors: array of {factor_id, name, effect, detail, ...}
  if (overlay.rate_factors && Array.isArray(result.rate_factors)) {
    const rfOverlay = overlay.rate_factors as unknown as Record<string, Record<string, unknown>>;
    result.rate_factors = (result.rate_factors as Record<string, unknown>[]).map(f => {
      const patch = rfOverlay[f.factor_id as string];
      return patch ? { ...f, ...patch } : f;
    });
  }
  // catalyst_properties: {changes: string[], does_not_change: string[]}
  if (overlay.catalyst_properties) {
    result.catalyst_properties = { ...(result.catalyst_properties as object), ...overlay.catalyst_properties };
  }
  // common_catalysts: array of {catalyst, name, reaction}, overlay keyed by catalyst
  if (overlay.common_catalysts && Array.isArray(result.common_catalysts)) {
    const ccOverlay = overlay.common_catalysts as unknown as Record<string, Record<string, unknown>>;
    result.common_catalysts = (result.common_catalysts as Record<string, unknown>[]).map(c => {
      const patch = ccOverlay[c.catalyst as string];
      return patch ? { ...c, ...patch } : c;
    });
  }
  // equilibrium_shifts: array of {factor, shift, explanation}, overlay keyed by factor
  if (overlay.equilibrium_shifts && Array.isArray(result.equilibrium_shifts)) {
    const esOverlay = overlay.equilibrium_shifts as unknown as Record<string, Record<string, unknown>>;
    result.equilibrium_shifts = (result.equilibrium_shifts as Record<string, unknown>[]).map(s => {
      const patch = esOverlay[s.factor as string];
      return patch ? { ...s, ...patch } : s;
    });
  }
  // heat_classification: {exothermic, endothermic, examples_exo, examples_endo}
  if (overlay.heat_classification) {
    result.heat_classification = { ...(result.heat_classification as object), ...overlay.heat_classification };
  }
  return result;
}

// Load overlays per content type and apply
const cp = { ...contentProps };
if (cp.type === 'exchange') {
  const [tmplOverlay, ruleTexts] = await Promise.all([
    loadBuildOverlay(locale, 'reaction_templates'),
    cachedReadDerived<Array<{ rule_id: string; slots: { canonical_summary?: Record<string, string> } }>>(
      ['rules', 'rule_texts'],
    ),
  ]);
  cp.templates = applyArrayOverlay(cp.templates as Record<string, unknown>[], tmplOverlay, 'id');
  // Build localized driving force entries from rule_texts.
  // Only include exchange-relevant rule types; deduplicate by text.
  const DRIVING_FORCE_TYPES = new Set([
    'exchange_reaction_condition', 'gas_forming_condition',
  ]);
  if (ruleTexts) {
    const baseRules = cp.rules as Record<string, unknown>[];
    const typeById = new Map(baseRules.map(r => [r.id as string, r.type as string]));
    const seen = new Set<string>();
    cp.rules = ruleTexts
      .filter(rt => DRIVING_FORCE_TYPES.has(typeById.get(rt.rule_id) ?? ''))
      .map(rt => ({
        id: rt.rule_id,
        text: rt.slots.canonical_summary?.[locale] ?? rt.slots.canonical_summary?.ru ?? '',
      }))
      .filter(r => {
        if (!r.text || seen.has(r.text)) return false;
        seen.add(r.text);
        return true;
      });
  }
} else if (cp.type === 'rate' || cp.type === 'catalyst') {
  const ecOverlay = await loadBuildOverlay(locale, 'energy_catalyst_theory');
  if (cp.type === 'rate') {
    cp.theory = applyEnergyOverlay(cp.theory as Record<string, unknown>, ecOverlay);
  } else {
    const patched = applyEnergyOverlay(
      { catalyst_properties: cp.catalystProperties, common_catalysts: cp.commonCatalysts } as Record<string, unknown>,
      ecOverlay,
    );
    cp.catalystProperties = patched.catalyst_properties;
    cp.commonCatalysts = patched.common_catalysts;
  }
} else if (cp.type === 'classRules') {
  const crOverlay = await loadBuildOverlay(locale, 'classification_rules');
  cp.rules = applyArrayOverlay(cp.rules as Record<string, unknown>[], crOverlay, 'id');
} else if (cp.type === 'naming') {
  const nrOverlay = await loadBuildOverlay(locale, 'naming_rules');
  if (nrOverlay) {
    cp.rules = (cp.rules as Record<string, unknown>[]).map(rule => {
      const patch = nrOverlay[rule.id as string];
      if (!patch) return rule;
      const merged = { ...rule, ...patch };
      // Deep-merge examples array if present
      if (patch.examples && Array.isArray(patch.examples)) {
        merged.examples = patch.examples;
      }
      return merged;
    });
  }
} else if (cp.type === 'qualTests') {
  const qtOverlay = await loadBuildOverlay(locale, 'qualitative_reactions');
  cp.tests = applyArrayOverlay(cp.tests as Record<string, unknown>[], qtOverlay, 'target_id');
} else if (cp.type === 'chains') {
  const gcOverlay = await loadBuildOverlay(locale, 'genetic_chains');
  cp.chains = applyArrayOverlay(cp.chains as Record<string, unknown>[], gcOverlay, 'chain_id');
}
---

<BaseLayout
  title={`${competency.name} — ${siteName}`}
  description={competency.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LearningResource",
      "name": competency.name,
      "description": competency.description,
      "educationalLevel": "ОГЭ, 9 класс",
      "learningResourceType": "Practice problem",
      "inLanguage": locale,
      "isPartOf": {
        "@type": "Course",
        "name": siteName,
        "url": siteUrl,
        "provider": { "@type": "Organization", "name": "Химия без магии", "url": siteUrl },
      },
      ...(competency.link ? { "url": `${siteUrl}${localizeUrl(competency.link, locale)}` } : {}),
      ...(competency.oge_task_types?.length ? { "teaches": competency.oge_task_types.map((t: string) => `Задание ОГЭ ${t}`) } : {}),
    })} />
  </Fragment>
  <article class="comp-page container">
    <div class="comp-page__header">
      <span class="comp-page__badge">{m.comp_block()} {competency.block} — {competency.block_name}</span>
      <h1 class="comp-page__title">{competency.name}</h1>
      <p class="comp-page__desc">{competency.description}</p>
    </div>

    <section class="comp-page__section">
      <h2>{m.comp_mastery()}</h2>
      <CompetencyMasteryIsland client:idle id={competency.id} name={competency.name} />
    </section>

    {/* Reference content section */}
    <section class="comp-page__content comp-page__section">
      <h2>{m.comp_reference()}</h2>

      {cid === 'periodic_table' && (
        <div>
          <p class="comp-content__intro">{m.comp_ref_periodic_desc()}</p>
          <ul class="comp-content__list">
            <li>{m.comp_ref_periodic_metals()}</li>
            <li>{m.comp_ref_periodic_z()}</li>
          </ul>
        </div>
      )}

      {cid === 'electron_config' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_econfig_klechkowski()}</li>
            <li>{m.comp_ref_econfig_hund()}</li>
            <li>{m.comp_ref_econfig_pauli()}</li>
          </ul>
          <div class="comp-content__formula">{m.comp_ref_econfig_order()}</div>
          <p class="comp-content__note">{m.comp_ref_econfig_exceptions()}</p>
        </div>
      )}

      {cid === 'periodic_trends' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_trends_radius()}</li>
            <li>{m.comp_ref_trends_en()}</li>
            <li>{m.comp_ref_trends_ie()}</li>
            <li>{m.comp_ref_trends_metallic()}</li>
          </ul>
          <p class="comp-content__note">{m.comp_ref_trends_reason()}</p>
        </div>
      )}

      {cid === 'oxidation_states' && (
        <div>
          <p class="comp-content__intro">{m.comp_ref_ox_rules()}</p>
          <ul class="comp-content__list">
            <li>{m.comp_ref_ox_rule1()}</li>
            <li>{m.comp_ref_ox_rule2()}</li>
            <li>{m.comp_ref_ox_rule3()}</li>
            <li>{m.comp_ref_ox_rule4()}</li>
            <li>{m.comp_ref_ox_rule5()}</li>
            <li>{m.comp_ref_ox_rule6()}</li>
          </ul>
        </div>
      )}

      {cid === 'bond_type' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_bond_ionic()}</li>
            <li>{m.comp_ref_bond_cov_polar()}</li>
            <li>{m.comp_ref_bond_cov_nonpolar()}</li>
            <li>{m.comp_ref_bond_metallic()}</li>
          </ul>
        </div>
      )}

      {cid === 'crystal_structure_type' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_crystal_ionic()}</li>
            <li>{m.comp_ref_crystal_molecular()}</li>
            <li>{m.comp_ref_crystal_atomic()}</li>
            <li>{m.comp_ref_crystal_metallic()}</li>
          </ul>
        </div>
      )}

      {cid === 'amphoterism_logic' && (
        <div>
          <p class="comp-content__intro">{m.comp_ref_ampho_elements()}</p>
          <div class="comp-content__formula">
            <div>{m.comp_ref_ampho_acid()}</div>
            <div>{m.comp_ref_ampho_base()}</div>
          </div>
          <p class="comp-content__note">{m.comp_ref_ampho_sign()}</p>
        </div>
      )}

      {cid === 'reactions_redox' && (
        <div>
          <p class="comp-content__intro">{m.rxn_theory_redox_desc()}</p>
          <ul class="comp-content__list">
            <li><strong>{m.rxn_theory_oxidizer()}</strong> — {m.rxn_theory_oxidizer_desc()}</li>
            <li><strong>{m.rxn_theory_reducer()}</strong> — {m.rxn_theory_reducer_desc()}</li>
          </ul>
          <p class="comp-content__note">{m.rxn_theory_mnemonic()}</p>
          <p class="comp-content__subtitle">{m.rxn_theory_electron_balance()}</p>
          <ol class="comp-content__list">
            <li>{m.rxn_theory_eb_step1()}</li>
            <li>{m.rxn_theory_eb_step2()}</li>
            <li>{m.rxn_theory_eb_step3()}</li>
            <li>{m.rxn_theory_eb_step4()}</li>
            <li>{m.rxn_theory_eb_step5()}</li>
          </ol>
        </div>
      )}

      {cid === 'gas_precipitate_logic' && (
        <div>
          <p class="comp-content__intro">{m.rxn_theory_forces()}</p>
          <p class="comp-content__subtitle">{m.rxn_theory_solubility()}</p>
          <SolubilityTable locale={locale} client:idle />
        </div>
      )}

      {cid === 'electrolyte_logic' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_electro_strong()}</li>
            <li>{m.comp_ref_electro_weak()}</li>
            <li>{m.comp_ref_electro_non()}</li>
          </ul>
          <p class="comp-content__note">{m.comp_ref_electro_dissoc()}</p>
        </div>
      )}

      {cid === 'ion_nomenclature' && (
        <div>
          <p class="comp-content__intro">{m.comp_ref_ion_nomen_intro()}</p>
          <ul class="comp-content__list">
            <li>{m.comp_ref_ion_nomen_ide()}</li>
            <li>{m.comp_ref_ion_nomen_ate()}</li>
            <li>{m.comp_ref_ion_nomen_ite()}</li>
            <li>{m.comp_ref_ion_nomen_per()}</li>
            <li>{m.comp_ref_ion_nomen_hypo()}</li>
          </ul>
        </div>
      )}

      {cid === 'calculations_basic' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_calc_basic_mr()}</li>
            <li>{m.comp_ref_calc_basic_n()}</li>
            <li>{m.comp_ref_calc_basic_omega()}</li>
          </ul>
        </div>
      )}

      {cid === 'calculations_solutions' && (
        <div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_calc_sol_omega()}</li>
            <li>{m.comp_ref_calc_sol_mass()}</li>
            <li>{m.comp_ref_calc_sol_dilution()}</li>
          </ul>
        </div>
      )}

      {cid === 'reaction_yield_logic' && (
        <div>
          <div class="comp-content__formula">{m.comp_ref_calc_yield_formula()}</div>
          <ul class="comp-content__list">
            <li>{m.comp_ref_calc_yield_steps()}</li>
            <li>{m.comp_ref_calc_yield_excess()}</li>
          </ul>
        </div>
      )}

      {cp.type === 'chains' && <ChainsContent chains={cp.chains as any} />}
      {cp.type === 'qualTests' && <QualTestsContent tests={cp.tests as any} />}
      {cp.type === 'rate' && <RateContent theory={cp.theory as any} />}
      {cp.type === 'catalyst' && <CatalystContent catalystProperties={cp.catalystProperties as any} commonCatalysts={cp.commonCatalysts as any} />}
      {cp.type === 'exchange' && <ExchangeContent templates={cp.templates as any} rules={cp.rules as any} />}
      {cp.type === 'classRules' && <ClassRulesContent rules={cp.rules as any} />}
      {cp.type === 'naming' && <NamingContent rules={cp.rules as any} />}
    </section>

    <section class="comp-page__section">
      <CompetencyPracticeIsland
        client:idle
        competencyId={competency.id}
        competencyName={competency.name}
        locale={locale}
      />
    </section>

    <section class="comp-page__section">
      <h2>{m.comp_prerequisites()}</h2>
      {prereqs.length > 0 ? (
        <ul class="comp-page__dep-list">
          {prereqs.map(p => (
            <li>
              <a href={localizeUrl(`/competency/${p.id}/`, locale)}>{p.name}</a>
              <span class="comp-page__dep-block">{p.block}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="comp-page__empty">{m.comp_no_prerequisites()}</p>
      )}
    </section>

    <section class="comp-page__section">
      <h2>{m.comp_unlocks()}</h2>
      {unlocks.length > 0 ? (
        <ul class="comp-page__dep-list">
          {unlocks.map(u => (
            <li>
              <a href={localizeUrl(`/competency/${u.id}/`, locale)}>{u.name}</a>
              <span class="comp-page__dep-block">{u.block}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="comp-page__empty">{m.comp_no_unlocks()}</p>
      )}
    </section>

    {competency.link && (
      <section class="comp-page__section">
        <h2>{m.comp_materials()}</h2>
        <a href={localizeUrl(competency.link, locale)} class="comp-page__material-link">
          {competency.name} &rarr;
        </a>
      </section>
    )}

    {competency.oge_task_types.length > 0 && (
      <section class="comp-page__section">
        <h2>{m.comp_oge_tasks()}</h2>
        <div class="comp-page__tasks">
          {competency.oge_task_types.map(n => (
            <a href={localizeUrl('/exam/', locale)} class="comp-page__task-badge">
              {n}
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="comp-page__actions">
      <a href={localizeUrl('/profile/', locale)}>&larr; {m.comp_back_to_profile()}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .comp-page {
    max-width: 720px;
    padding: var(--space-xl) var(--space-md);
  }

  .comp-page__header {
    margin-bottom: var(--space-xl);
  }

  .comp-page__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    background: #dbe4ff;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    margin-bottom: var(--space-sm);
  }

  .comp-page__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: var(--space-sm) 0;
  }

  .comp-page__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .comp-page__section {
    margin-bottom: var(--space-xl);
  }

  .comp-page__section h2 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-border);
  }

  .comp-page__dep-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .comp-page__dep-list li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }

  .comp-page__dep-list a {
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .comp-page__dep-block {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-muted);
    background: var(--color-border);
    padding: 0.1rem 0.35rem;
    border-radius: 0.2rem;
    margin-left: auto;
  }

  .comp-page__empty {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .comp-page__material-link {
    display: inline-block;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: border-color 0.15s;
  }

  .comp-page__material-link:hover {
    border-color: var(--color-primary);
    text-decoration: none;
  }

  .comp-page__tasks {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .comp-page__task-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .comp-page__task-badge:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }

  .comp-page__actions {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
</style>
