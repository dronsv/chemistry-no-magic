---
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MoleculeView from '../../components/MoleculeView';
import FormulaChip from '../../components/FormulaChip.tsx';
import type { SupportedLocale } from '../../types/i18n';
import { localizeUrl } from '../../lib/i18n';
import { loadBuildOverlay } from '../../lib/build-overlay';
import type { Props } from './substance-detail-paths';
import * as m from '../../paraglide/messages.js';

const { substance: baseSubstance, classificationRules: baseClassRules, namingRules: baseNamingRules, allSubstances: baseAllSubstances, ions: baseIons, substanceReactions: baseReactions } = Astro.props as Props;
const locale = (Astro.currentLocale ?? 'ru') as SupportedLocale;

// Apply locale overlays
const substance = { ...baseSubstance };
const substancesOverlay = await loadBuildOverlay(locale, 'substances');
if (substancesOverlay && substancesOverlay[substance.id]) {
  Object.assign(substance, substancesOverlay[substance.id]);
}

const displayName = substance.name_ru ?? substance.formula;

// Apply classification rules overlay
const classOverlay = await loadBuildOverlay(locale, 'classification_rules');
const classificationRules = baseClassRules.map(r => {
  if (classOverlay && classOverlay[r.id]) {
    return { ...r, ...classOverlay[r.id] };
  }
  return r;
});

// Apply naming rules overlay
const namingOverlay = await loadBuildOverlay(locale, 'naming_rules');
const namingRules = baseNamingRules.map(r => {
  if (namingOverlay && namingOverlay[r.id]) {
    const overlay = namingOverlay[r.id] as Record<string, unknown>;
    return {
      ...r,
      ...(overlay.template_ru ? { template_ru: overlay.template_ru as string } : {}),
      ...(overlay.examples ? { examples: overlay.examples as Array<{ formula: string; name_ru: string }> } : {}),
    };
  }
  return r;
});

// Apply reactions overlay
const reactionsOverlay = await loadBuildOverlay(locale, 'reactions');
const substanceReactions = baseReactions.map(r => {
  if (reactionsOverlay && reactionsOverlay[r.reaction_id]?.title) {
    return { ...r, title: reactionsOverlay[r.reaction_id].title as string };
  }
  return r;
});

// Apply ions overlay
const ionsOverlay = await loadBuildOverlay(locale, 'ions');
const ions: Record<string, typeof baseIons[string]> = {};
for (const [id, ion] of Object.entries(baseIons)) {
  if (ionsOverlay && ionsOverlay[id]?.name_ru) {
    ions[id] = { ...ion, name_ru: ionsOverlay[id].name_ru as string };
  } else {
    ions[id] = ion;
  }
}

// Apply substances overlay to allSubstances (for related substances names)
const allSubstances = baseAllSubstances.map(s => {
  if (substancesOverlay && substancesOverlay[s.id]?.name_ru) {
    return { ...s, name_ru: substancesOverlay[s.id].name_ru as string };
  }
  return s;
});

// Find matching classification rule
const classRule = classificationRules.find(
  r => r.class === substance.class && r.subclass === substance.subclass
);

// Find matching naming rule — check which rule's examples include this formula
const namingRule = namingRules.find(
  r => r.examples.some(ex => ex.formula === substance.formula)
) ?? namingRules.find(r => r.class === substance.class);

// Find the exact example for this substance (if exists in the matched rule)
const namingExample = namingRule?.examples.find(ex => ex.formula === substance.formula);

const CLASS_LABELS: Record<string, string> = {
  oxide: m.class_oxide(),
  acid: m.class_acid(),
  base: m.class_base(),
  salt: m.class_salt(),
  other: m.class_other(),
};

const SUBCLASS_LABELS: Record<string, string> = {
  basic: m.subclass_basic_lower(),
  acidic: m.subclass_acidic_lower(),
  amphoteric: m.subclass_amphoteric_lower(),
  indifferent: m.subclass_indifferent_lower(),
  oxygen_containing: m.subclass_oxygen_containing_lower(),
  oxygen_free: m.subclass_oxygen_free_lower(),
  soluble: m.subclass_soluble_lower(),
  insoluble: m.subclass_insoluble_lower(),
  normal: m.subclass_normal_lower(),
  acidic_salt: m.subclass_acidic_salt_lower(),
  basic_salt: m.subclass_basic_salt_lower(),
  hydride: m.subclass_hydride_lower(),
};

const TAG_LABELS: Record<string, string> = {
  soluble: m.stag_soluble(),
  insoluble: m.stag_insoluble(),
  slightly_soluble: m.stag_slightly_soluble(),
  strong_electrolyte: m.stag_strong_electrolyte(),
  weak_electrolyte: m.stag_weak_electrolyte(),
  amphoteric: m.stag_amphoteric(),
  oxidizer: m.stag_oxidizer(),
  reducer: m.stag_reducer(),
  strong_acid: m.stag_strong_acid(),
  medium_acid: m.stag_medium_acid(),
  weak_acid: m.stag_weak_acid(),
  alkali: m.stag_alkali(),
  diprotic: m.stag_diprotic(),
  triprotic: m.stag_triprotic(),
  unstable: m.stag_unstable(),
  decomposes: m.stag_decomposes(),
  decomposes_on_heating: m.stag_decomposes_on_heating(),
  reacts_with_water: m.stag_reacts_with_water(),
  no_water_reaction: m.stag_no_water_reaction(),
  gas: m.stag_gas(),
  pungent_odor: m.stag_pungent_odor(),
  white: m.stag_white(),
  black: m.stag_black(),
  blue: m.stag_blue(),
  red_brown: m.stag_red_brown(),
  gelatinous: m.stag_gelatinous(),
};

// Human-readable template: replace placeholders
const TEMPLATE_PLACEHOLDERS: Record<string, string> = {
  '{metal_genitive}': m.subst_detail_placeholder_metal(),
  '{roman_numeral}': m.subst_detail_placeholder_ox_state(),
  '{nonmetal_genitive}': m.subst_detail_placeholder_nonmetal(),
};
function humanizeTemplate(tpl: string): string {
  let result = tpl;
  for (const [key, label] of Object.entries(TEMPLATE_PLACEHOLDERS)) {
    result = result.replace(key, `[${label}]`);
  }
  return result;
}
const readableTemplate = namingRule ? humanizeTemplate(namingRule.template_ru) : null;

// Related substances (same class, same subclass first, then same class)
const related = allSubstances
  .filter(s => s.id !== substance.id && s.class === substance.class)
  .sort((a, b) => {
    const aMatch = a.subclass === substance.subclass ? 0 : 1;
    const bMatch = b.subclass === substance.subclass ? 0 : 1;
    return aMatch - bMatch;
  })
  .slice(0, 8);

const classLabel = CLASS_LABELS[substance.class] ?? substance.class;
const subclassLabel = substance.subclass ? (SUBCLASS_LABELS[substance.subclass] ?? substance.subclass) : null;

// Try to load molecule structure
let structure = null;
try {
  const structRaw = await readFile(
    join(process.cwd(), 'data-src', 'structures', `${substance.id}.json`), 'utf-8'
  );
  structure = JSON.parse(structRaw);
} catch { /* no structure for this substance */ }

const hasPhysical = substance.melting_point_C != null || substance.boiling_point_C != null || substance.density_g_cm3 != null || substance.appearance_ru;
const hasHazards = (substance.hazards_ru && substance.hazards_ru.length > 0) || substance.storage_ru;
const hasProduction = substance.production_ru || substance.industrial_ru;
const hasFacts = substance.fun_facts_ru && substance.fun_facts_ru.length > 0;
---

<BaseLayout
  title={displayName}
  description={m.subst_detail_description({ name: displayName, formula: substance.formula })}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ChemicalSubstance",
      "name": displayName,
      "molecularFormula": substance.formula,
      "description": `${displayName} — ${classLabel}`,
      "inLanguage": locale,
    })} />
  </Fragment>

  <article class="substance-page">
    <h1>{substance.formula}</h1>
    {substance.name_ru && <p class="substance-name">{substance.name_ru}</p>}

    <dl class="substance-props">
      <dt>{m.subst_detail_class_label()}</dt>
      <dd>
        <span class={`subst-card__badge subst-card__badge--${substance.class}`}>
          {classLabel}
        </span>
        {subclassLabel && <span class="substance-subclass"> ({subclassLabel})</span>}
      </dd>

      {substance.ions && substance.ions.length > 0 && (
        <>
          <dt>{m.subst_detail_ions_label()}</dt>
          <dd class="substance-ions">
            {substance.ions.map((ionId, i) => {
              const ion = ions[ionId];
              return (
                <>
                  {i > 0 && ' '}
                  {ion ? (
                    <FormulaChip
                      formula={ion.formula}
                      name={ion.name_ru}
                      ionType={ion.type === 'cation' ? 'cation' : 'anion'}
                    />
                  ) : ionId}
                </>
              );
            })}
          </dd>
        </>
      )}

      {substance.tags && substance.tags.length > 0 && (
        <>
          <dt>{m.subst_detail_properties_label()}</dt>
          <dd class="substance-tags">
            {substance.tags.map(tag => (
              <span class="substance-tag">{TAG_LABELS[tag] ?? tag}</span>
            ))}
          </dd>
        </>
      )}
    </dl>

    {substance.notes && <p class="substance-notes">{substance.notes}</p>}

    {classRule && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_classification()}</h3>
        <div class="subst-detail__explanation">{classRule.description_ru}</div>
      </div>
    )}

    {namingRule && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_nomenclature()}</h3>
        <div class="subst-detail__explanation">
          <div>{m.subst_detail_template_prefix()}<span class="subst-detail__template">{readableTemplate}</span></div>
          {namingExample && (
            <div class="subst-detail__naming-result">
              {namingExample.formula} &rarr; <strong>{namingExample.name_ru}</strong>
            </div>
          )}
        </div>
      </div>
    )}

    {structure && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_structure()}</h3>
        <MoleculeView
          client:idle
          structure={structure}
          layers={{ bonds: true, oxStates: false, charges: false, lonePairs: false }}
          size="md"
          interactive={true}
        />
      </div>
    )}

    {hasPhysical && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_physical()}</h3>
        {substance.appearance_ru && (
          <p class="subst-detail__appearance">{substance.appearance_ru}</p>
        )}
        <dl class="subst-detail__phys-props">
          {substance.melting_point_C != null && (
            <>
              <dt>{m.prop_melting()}</dt>
              <dd>{substance.melting_point_C} °C</dd>
            </>
          )}
          {substance.boiling_point_C != null && (
            <>
              <dt>{m.subst_detail_boiling()}</dt>
              <dd>{substance.boiling_point_C} °C</dd>
            </>
          )}
          {substance.density_g_cm3 != null && (
            <>
              <dt>{m.subst_detail_density()}</dt>
              <dd>{substance.density_g_cm3} {m.subst_detail_density_unit()}</dd>
            </>
          )}
        </dl>
      </div>
    )}

    {hasHazards && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_hazards()}</h3>
        {substance.hazards_ru && substance.hazards_ru.length > 0 && (
          <div class="subst-detail__hazards">
            {substance.hazards_ru.map(h => (
              <span class="subst-detail__hazard-tag">{h}</span>
            ))}
          </div>
        )}
        {substance.storage_ru && (
          <p class="subst-detail__storage">{substance.storage_ru}</p>
        )}
      </div>
    )}

    {hasProduction && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_production()}</h3>
        {substance.production_ru && (
          <div class="subst-detail__explanation">{substance.production_ru}</div>
        )}
        {substance.industrial_ru && (
          <p class="subst-detail__text">{substance.industrial_ru}</p>
        )}
      </div>
    )}

    {substanceReactions.length > 0 && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_reactions()}</h3>
        <ul class="subst-detail__reactions">
          {substanceReactions.map(r => (
            <li>
              <a href={`${localizeUrl('/reactions/', locale)}#${r.reaction_id}`}>{r.equation}</a>
              <span class="subst-detail__reaction-title">{r.title}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {hasFacts && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_facts()}</h3>
        <ul class="subst-detail__facts">
          {substance.fun_facts_ru!.map(f => (
            <li>{f}</li>
          ))}
        </ul>
      </div>
    )}

    {related.length > 0 && (
      <div class="subst-detail__section">
        <h3>{m.subst_detail_related()}</h3>
        <div class="subst-detail__related">
          {related.map(r => (
            <FormulaChip
              formula={r.formula}
              name={r.name_ru}
              substanceId={r.id}
              substanceClass={r.class}
              locale={locale}
            />
          ))}
        </div>
      </div>
    )}

    <div class="substance-page__actions">
      <a href={localizeUrl('/substances/', locale)}>{m.subst_detail_back()}</a>
      <a href={localizeUrl('/substances/', locale)} class="btn btn-primary substance-page__practice-link">{m.subst_detail_practice()}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .substance-page {
    max-width: 640px;
    padding: var(--space-xl) 0;
  }
  .substance-page h1 {
    font-size: 2rem;
    margin: 0 0 var(--space-xs);
  }
  .substance-name {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    margin: 0 0 var(--space-xl);
  }
  .substance-subclass {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .substance-props {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm) var(--space-lg);
    margin-bottom: var(--space-xl);
    align-items: center;
  }
  .substance-props dt {
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .substance-props dd { margin: 0; }
  .substance-ions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .substance-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .substance-tag {
    font-size: 0.8125rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-text-muted);
  }
  .substance-notes {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }
  .substance-page__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
  .substance-page__practice-link {
    margin-left: auto;
  }

  /* Section styles (inline since substances.css is only loaded on index) */
  .subst-detail__section {
    margin-bottom: var(--space-lg);
  }
  .subst-detail__section h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
  }
  .subst-detail__explanation {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    border-radius: 0.25rem;
    margin-bottom: var(--space-sm);
  }
  .subst-detail__template {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 600;
  }
  .subst-detail__naming-result {
    margin-top: var(--space-xs);
    font-size: 0.9375rem;
  }
  .subst-detail__related {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  /* Physical properties */
  .subst-detail__appearance {
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    font-style: italic;
  }
  .subst-detail__phys-props {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-lg);
    font-size: 0.875rem;
  }
  .subst-detail__phys-props dt {
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .subst-detail__phys-props dd {
    margin: 0;
  }

  /* Hazards */
  .subst-detail__hazards {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }
  .subst-detail__hazard-tag {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    font-size: 0.8125rem;
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
    border-radius: 0.25rem;
    font-weight: 500;
  }
  .subst-detail__storage {
    font-size: 0.875rem;
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-alt);
    border-left: 3px solid #f59e0b;
    border-radius: 0.25rem;
  }
  .subst-detail__text {
    font-size: 0.875rem;
    margin: var(--space-xs) 0 0;
    line-height: 1.6;
  }

  /* Reactions */
  .subst-detail__reactions {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .subst-detail__reactions li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .subst-detail__reactions li:last-child {
    border-bottom: none;
  }
  .subst-detail__reactions a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .subst-detail__reaction-title {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Facts */
  .subst-detail__facts {
    margin: 0;
    padding-left: var(--space-lg);
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .subst-detail__facts li {
    margin-bottom: var(--space-xs);
  }
</style>
