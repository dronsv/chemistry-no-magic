---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConceptModuleIsland from './ConceptModuleIsland.tsx';
import ContextBackLink from '../../components/ContextBackLink.tsx';
import { CONCEPT_KIND_ROUTES, localizeUrl } from '../../lib/i18n';
import type { SupportedLocale } from '../../types/i18n';
import type { ConceptPageProps } from './concept-detail-paths';
import * as m from '../../paraglide/messages.js';

const { conceptId, entry, overlay, locale, breadcrumbs, children, substanceIndex, alternateUrls } = Astro.props as ConceptPageProps;
const loc = locale as SupportedLocale;

const baseRoute = CONCEPT_KIND_ROUTES[entry.kind] ?? '/';
const localizedBase = localizeUrl(baseRoute, loc);

// Back link label per kind
const backLabels: Record<string, string> = {
  substance_class: m.concept_back_substances(),
  element_group: m.concept_back_elements(),
  reaction_type: m.concept_back_reactions(),
  reaction_facet: m.concept_back_reactions(),
};
const backLabel = backLabels[entry.kind] ?? m.back();

// Context back link labels (for returning to exam/practice/diagnostics)
const contextBackLabels = {
  exam: m.back_to_exam(),
  practice: m.back_to_practice(),
  diagnostics: m.back_to_diagnostics(),
  previous: m.back_to_previous(),
};

// SEO description from overlay or fallback
const seoDescription = overlay.description
  ? overlay.description
  : m.concept_description({ name: overlay.name });
---

<BaseLayout
  title={overlay.name}
  description={seoDescription}
  alternateUrls={alternateUrls}
>
  <article class="concept-page">
    <ContextBackLink client:idle labels={contextBackLabels} />
    <nav class="concept-breadcrumbs" aria-label="breadcrumbs">
      <a href={localizedBase}>{backLabel}</a>
      {breadcrumbs.map((crumb) => (
        <span>
          <span class="sep"> / </span>
          <a href={localizedBase + crumb.href}>{crumb.name}</a>
        </span>
      ))}
      <span class="sep"> / </span>
      <span class="current">{overlay.name}</span>
    </nav>

    <h1>{overlay.name}</h1>

    {/* SEO teaser text (visible before JS loads) */}
    {overlay.description && (
      <p class="concept-teaser">{overlay.description}</p>
    )}

    {/* SSG children links (SEO-crawlable) */}
    {children.length > 0 && (
      <nav class="concept-children-ssg" aria-label={m.concept_subcategories()}>
        <ul>
          {children.map((child) => (
            <li>
              <a href={localizedBase + child.slug + '/'}>{child.name}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    {/* CSR island — loads full content client-side */}
    <ConceptModuleIsland client:idle conceptId={conceptId} locale={locale} />

    <div class="concept-page__actions">
      <a href={localizedBase}>&larr; {backLabel}</a>
    </div>
  </article>
</BaseLayout>

<style>
  .concept-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-xl, 2rem) var(--space-md, 1rem);
  }
  .concept-breadcrumbs {
    font-size: 0.875rem;
    margin-bottom: var(--space-md, 1rem);
    color: var(--color-text-muted, #64748b);
  }
  .concept-breadcrumbs a {
    color: var(--color-link, #2563eb);
    text-decoration: none;
  }
  .concept-breadcrumbs a:hover {
    text-decoration: underline;
  }
  .concept-breadcrumbs .current {
    font-weight: 600;
    color: var(--color-text, #1e293b);
  }
  .sep {
    margin: 0 0.25rem;
  }
  h1 {
    font-size: 1.75rem;
    margin: 0 0 var(--space-sm, 0.75rem);
  }
  .concept-teaser {
    color: var(--color-text-muted, #64748b);
    margin: 0 0 var(--space-lg, 1.5rem);
    font-size: 1.05rem;
    line-height: 1.5;
  }
  .concept-children-ssg ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-lg, 1.5rem);
  }
  .concept-children-ssg li a {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    border-radius: 0.25rem;
    background: var(--color-bg-alt, #f1f5f9);
    text-decoration: none;
    color: var(--color-link, #2563eb);
    font-weight: 500;
  }
  .concept-children-ssg li a:hover {
    background: var(--color-bg-hover, #e2e8f0);
  }
  h2 {
    font-size: 1.1rem;
    margin: var(--space-lg, 1.5rem) 0 var(--space-sm, 0.75rem);
  }
  .concept-page__actions {
    margin-top: var(--space-xl, 2rem);
    padding-top: var(--space-md, 1rem);
    border-top: 1px solid var(--color-border, #e2e8f0);
  }
  .concept-page__actions a {
    color: var(--color-link, #2563eb);
    text-decoration: none;
  }
  .concept-page__actions a:hover {
    text-decoration: underline;
  }
</style>
