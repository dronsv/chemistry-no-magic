---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TheoryModulePanel from '../../components/TheoryModulePanel';
import { cachedReadDataSrcSync } from '../../lib/build-data-cache';
import { loadBuildOverlay } from '../../lib/build-overlay';
import type { Topic, TopicPage, TopicPagesMap, TopicPageLocaleOverlay, TopicLocaleOverlay, FAQItem } from '../../types/topic';
import type { SupportedLocale } from '../../types/i18n';
import type { TopicDetailProps } from './topic-detail-paths';
import { localizeUrl, SITE_NAME, SUPPORTED_LOCALES } from '../../lib/i18n';

const { topicId, locale } = Astro.props as TopicDetailProps;

// Load base data (sync — in build cache after first topic in section)
const allTopics: Topic[] = cachedReadDataSrcSync('topics.json');
const topicPages: TopicPagesMap = cachedReadDataSrcSync('topic_pages.json');
const baseTopic = allTopics.find(t => t.id === topicId)!;
const baseTopicPage: TopicPage | null = topicPages[topicId] ?? null;

// Load locale overlays for current locale (async, cached per build)
const topicOverlay = await loadBuildOverlay(locale, 'topics') as TopicLocaleOverlay | null;
const topicPagesOverlay = await loadBuildOverlay(locale, 'topic_pages') as TopicPageLocaleOverlay | null;

// Merge: base fields + locale overlay (overlay keys: title, summary, slug)
const topicLocaleFields = topicOverlay?.[topicId];
const topic = topicLocaleFields ? { ...baseTopic, ...topicLocaleFields } : baseTopic;
// Prefer localized title, fall back to title_ru
const topicTitle: string = (topic as { title?: string }).title ?? topic.title_ru;
const topicSummary: string = (topic as { summary?: string }).summary ?? topic.summary_ru;

const localeTopicPage = topicPagesOverlay?.[topicId];
const seoTitle = localeTopicPage?.seo_title ?? baseTopicPage?.seo_title ?? topic.title;
const description = topic.summary;
const faq: FAQItem[] = localeTopicPage?.faq ?? baseTopicPage?.faq ?? [];

// Section nav
const sectionPath = `/${baseTopic.section}/`;
const sectionUrl = localizeUrl(sectionPath, locale);

const SECTION_LABELS: Record<string, Record<SupportedLocale, string>> = {
  'bonds':            { ru: 'Химическая связь',  en: 'Chemical Bonds',   pl: 'Wiązania chemiczne', es: 'Enlaces químicos'     },
  'oxidation-states': { ru: 'Степени окисления', en: 'Oxidation States', pl: 'Stopnie utlenienia', es: 'Estados de oxidación' },
  'calculations':     { ru: 'Расчёты',           en: 'Calculations',     pl: 'Obliczenia',         es: 'Cálculos'             },
};
const SECTION_PATHS: Record<string, Record<SupportedLocale, string>> = {
  'bonds':            { ru: '/bonds/',            en: '/en/bonds/',            pl: '/pl/wiazania/',            es: '/es/enlaces/'             },
  'oxidation-states': { ru: '/oxidation-states/', en: '/en/oxidation-states/', pl: '/pl/stopnie-utlenienia/',  es: '/es/estados-oxidacion/'   },
  'calculations':     { ru: '/calculations/',     en: '/en/calculations/',     pl: '/pl/obliczenia/',          es: '/es/calculos/'            },
};

const FAQ_HEADING: Record<SupportedLocale, string> = {
  ru: 'Частые вопросы', en: 'Frequently Asked Questions',
  pl: 'Często zadawane pytania', es: 'Preguntas frecuentes',
};
const THEORY_HEADING: Record<SupportedLocale, string> = {
  ru: 'Теория', en: 'Theory', pl: 'Teoria', es: 'Teoría',
};
const RELATED_HEADING: Record<SupportedLocale, string> = {
  ru: 'Связанные темы', en: 'Related topics', pl: 'Powiązane tematy', es: 'Temas relacionados',
};
const CALC_CTA: Record<SupportedLocale, string> = {
  ru: 'Открыть калькулятор', en: 'Open calculator',
  pl: 'Otwórz kalkulator', es: 'Abrir calculadora',
};
const HOME_LABEL: Record<SupportedLocale, string> = {
  ru: 'Главная', en: 'Home', pl: 'Strona główna', es: 'Inicio',
};

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const sectionLabel = SECTION_LABELS[baseTopic.section]?.[locale] ?? baseTopic.section;

// Extract moduleKey: "module:bonds_and_crystals.v1" → "bonds_and_crystals"
const firstRef = topic.theory_refs[0] ?? null;
const moduleKey = firstRef
  ? firstRef.module.replace(/^module:/, '').replace(/\.\w+$/, '')
  : null;
const forceSectionId = firstRef?.section_id;

// Related topics — load titles in current locale
const relatedTopics = topic.related_topic_ids
  .map(rid => allTopics.find(t => t.id === rid))
  .filter(Boolean) as Topic[];
const relatedItems = relatedTopics.map(rt => {
  const lf = topicOverlay?.[rt.id];
  const rtTitle: string = (lf as { title?: string } | undefined)?.title ?? rt.title_ru;
  const rtSlug: string = (lf as { slug?: string } | undefined)?.slug ?? rt.slug;
  const rtSectionPath = SECTION_PATHS[rt.section]?.[locale] ?? localizeUrl(`/${rt.section}/`, locale);
  return { href: `${rtSectionPath}${rtSlug}/`, title: rtTitle };
});

// Hreflang alternate URLs — resolve slug per locale
const alternateUrls = {} as Record<SupportedLocale, string>;
for (const loc of SUPPORTED_LOCALES) {
  const locOverlay = loc === locale
    ? (topicOverlay as TopicLocaleOverlay | null)
    : (await loadBuildOverlay(loc, 'topics') as TopicLocaleOverlay | null);
  const locSlug = (locOverlay?.[topicId] as { slug?: string } | undefined)?.slug ?? baseTopic.slug;
  const secPath = SECTION_PATHS[baseTopic.section]?.[loc] ?? localizeUrl(sectionPath, loc);
  alternateUrls[loc] = `${secPath}${locSlug}/`;
}

// JSON-LD schemas
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(q => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
} : null;

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: seoTitle.replace(/\s*\|.*$/, ''),
  description: topicSummary,
  provider: { '@type': 'Organization', name: SITE_NAME[locale], url: siteUrl },
  inLanguage: locale,
  isAccessibleForFree: true,
  url: Astro.url.href,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: HOME_LABEL[locale], item: Astro.url.origin + '/' },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: Astro.url.origin + sectionUrl },
    { '@type': 'ListItem', position: 3, name: topic.title },
  ],
};
---

<BaseLayout title={seoTitle} description={topicSummary} alternateUrls={alternateUrls}>
  <Fragment slot="head">
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="topic-page">
    <nav class="topic-breadcrumb" aria-label="breadcrumb">
      <ol>
        <li><a href="/">{HOME_LABEL[locale]}</a></li>
        <li><a href={sectionUrl}>{sectionLabel}</a></li>
        <li aria-current="page">{topic.title}</li>
      </ol>
    </nav>

    <h1 class="topic-title">{topic.title}</h1>
    <p class="topic-summary">{description}</p>

    {moduleKey && (
      <section class="topic-theory">
        <h2 class="topic-section-heading">{THEORY_HEADING[locale]}</h2>
        <TheoryModulePanel
          moduleKey={moduleKey}
          pageKey={topicId}
          locale={locale}
          forceSectionId={forceSectionId}
          client:idle
        />
      </section>
    )}

    {faq.length > 0 && (
      <section class="topic-faq">
        <h2 class="topic-section-heading">{FAQ_HEADING[locale]}</h2>
        {faq.map(item => (
          <details class="faq-item">
            <summary class="faq-question">{item.question}</summary>
            <p class="faq-answer">{item.answer}</p>
          </details>
        ))}
      </section>
    )}

    {relatedItems.length > 0 && (
      <section class="topic-related">
        <h2 class="topic-section-heading">{RELATED_HEADING[locale]}</h2>
        <ul class="related-list">
          {relatedItems.map(item => (
            <li><a href={item.href}>{item.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    <aside class="topic-cta">
      <a href={sectionUrl} class="topic-cta-link">{CALC_CTA[locale]} →</a>
    </aside>
  </div>
</BaseLayout>

<style>
  .topic-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .topic-breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted, #6b7280);
    flex-wrap: wrap;
  }

  .topic-breadcrumb li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    opacity: 0.5;
  }

  .topic-breadcrumb a {
    color: var(--color-primary, #2563eb);
    text-decoration: none;
  }

  .topic-breadcrumb a:hover { text-decoration: underline; }

  .topic-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .topic-summary {
    font-size: 1.05rem;
    color: var(--text-secondary, #374151);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .topic-section-heading {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .topic-theory,
  .topic-faq,
  .topic-related {
    margin-bottom: 2rem;
  }

  .faq-item {
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 0.5rem;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }

  .faq-question {
    cursor: pointer;
    padding: 0.85rem 1rem;
    font-weight: 600;
    list-style: none;
    background: var(--surface-alt, #f9fafb);
    user-select: none;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::before {
    content: '›';
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform 0.2s;
  }

  details[open] .faq-question::before { transform: rotate(90deg); }

  .faq-answer {
    padding: 0.85rem 1rem;
    margin: 0;
    line-height: 1.65;
    color: var(--text-secondary, #374151);
    border-top: 1px solid var(--border-color, #e5e7eb);
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related-list a {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: var(--surface-alt, #f9fafb);
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 2rem;
    color: var(--color-primary, #2563eb);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .related-list a:hover {
    background: var(--color-primary, #2563eb);
    border-color: var(--color-primary, #2563eb);
    color: #fff;
  }

  .topic-cta {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--surface-alt, #f9fafb);
    border-radius: 0.75rem;
    text-align: center;
  }

  .topic-cta-link {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .topic-cta-link:hover { opacity: 0.9; }
</style>
