{
  "suffix_rules": [
    { "id": "binary_ide",    "suffix": "-ide",  "description": "Binary anions (no oxygen) → suffix -ide" },
    { "id": "oxy_max_ate",   "suffix": "-ate",  "description": "Oxoacid with max oxidation state of central atom → -ate" },
    { "id": "oxy_lower_ite", "suffix": "-ite",  "description": "Oxoacid with lower oxidation state → -ite" },
    { "id": "per_prefix",    "prefix": "per-",  "suffix": "-ate", "description": "Oxidation state above typical maximum → prefix per- + suffix -ate" },
    { "id": "hypo_prefix",   "prefix": "hypo-", "suffix": "-ite", "description": "Oxidation state below typical minimum for oxy-anions → prefix hypo- + suffix -ite" }
  ],
