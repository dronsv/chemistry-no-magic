  "structures": {
    "Measurement": {
      "type": "object",
      "required": [
        "quantity",
        "value",
        "unit"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Optional ID like meas:1"
        },
        "quantity": {
          "type": "string",
          "description": "Quantity type ID, e.g. q:mass"
        },
        "value": {
          "type": [
            "number",
            "string"
          ],
          "description": "Numeric value, or string for enum conditions"
        },
        "unit": {
          "type": "string",
          "description": "Unit ID, e.g. unit:g"
        },
        "of": {
          "type": "string",
          "description": "Optional link to chemical entity, e.g. sub:Zn_s"
        },
        "at": {
          "type": "array",
          "description": "Optional conditions (Measurements) for this measurement",
          "items": {
            "$ref": "#/structures/Measurement"
          }
        }
