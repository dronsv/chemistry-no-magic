{
  "ruleset_id": "oxidation_rules.school.v1",
  "rules": [
    {
      "id": "simple_substance",
      "kind": "assignment",
      "examples": [
        "O2",
        "Fe",
        "Cl2"
      ]
    },
    {
      "id": "fluorine",
      "kind": "assignment",
      "examples": [
        "HF",
        "CaF2"
      ]
    },
    {
      "id": "group1",
      "kind": "assignment",
      "examples": [
        "NaCl",
        "KOH",
        "Li2O"
      ]
    },
    {
      "id": "group2",
      "kind": "assignment",
      "examples": [
        "CaO",
        "MgCl2",
        "BaSO4"
      ]
    },
    {
      "id": "aluminum",
      "kind": "assignment",
      "examples": [
        "Al2O3",
        "AlCl3",
        "Al(OH)3"
      ]
    },
    {
      "id": "oxygen",
      "kind": "default",
      "examples": [
        "H2O",
        "SO3",
        "Fe2O3"
      ]
    },
    {
      "id": "oxygen_peroxide",
      "kind": "exception",
      "examples": [
        "H2O2",
        "Na2O2",
        "BaO2"
      ]
    },
    {
      "id": "hydrogen",
      "kind": "default",
      "examples": [
        "H2O",
        "HCl",
        "NH3"
      ]
    },
    {
      "id": "hydrogen_hydride",
      "kind": "exception",
      "examples": [
        "NaH",
        "CaH2"
      ]
    },
    {
      "id": "algebraic",
      "kind": "assignment",
      "examples": [
        "KMnO4",
        "H2SO4"
      ]
    },
    {
      "id": "sum_equals_zero",
      "kind": "constraint"
    }
  ]
}
