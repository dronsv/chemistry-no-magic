{
  "id": "module:calculations.v1",
  "kind": "theory_module",
  "applies_to": [],
  "sections": [
    {
      "id": "molar_mass",
      "title_ru": "Молярная масса",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Молярная масса (M) — масса одного моля вещества, измеряется в г/моль."
        },
        {
          "t": "equation",
          "text_ru": "M = Σ(Ar × число атомов)"
        },
        {
          "t": "paragraph",
          "text_ru": "Где Ar — относительная атомная масса элемента (из таблицы Менделеева)."
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "M(H₂SO₄) = 2×1 + 32 + 4×16 = 98 г/моль"
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "M(Ca(OH)₂) = 40 + 2×(16+1) = 74 г/моль"
        }
      ]
    },
    {
      "id": "amount",
      "title_ru": "Количество вещества",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Количество вещества (n) — число молей, связывает массу с молярной массой."
        },
        {
          "t": "equation",
          "text_ru": "n = m / M"
        },
        {
          "t": "equation",
          "text_ru": "m = n × M"
        },
        {
          "t": "equation",
          "text_ru": "V = n × Vm (для газов, Vm = 22,4 л/моль при н.у.)"
        },
        {
          "t": "equation",
          "text_ru": "N = n × NA (NA = 6,02 × 10²³)"
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "Сколько моль в 49 г H₂SO₄? → n = 49/98 = 0,5 моль"
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "Масса 3 моль NaCl? → m = 3 × 58,5 = 175,5 г"
        }
      ]
    },
    {
      "id": "mass_fraction_element",
      "title_ru": "Массовая доля элемента",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Массовая доля элемента (ω) — доля массы данного элемента в общей массе вещества."
        },
        {
          "t": "equation",
          "text_ru": "ω(E) = n × Ar(E) / M(вещества) × 100%"
        },
        {
          "t": "paragraph",
          "text_ru": "Где n — число атомов элемента в формуле."
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "ω(O) в H₂O = 16/18 × 100% = 88,9%"
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "ω(N) в NH₃ = 14/17 × 100% = 82,4%"
        }
      ]
    },
    {
      "id": "solution_fraction",
      "title_ru": "Массовая доля растворённого вещества",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Массовая доля растворённого вещества (ω) — отношение массы растворённого вещества к массе раствора."
        },
        {
          "t": "equation",
          "text_ru": "ω = m(р.в.) / m(р-ра) × 100%"
        },
        {
          "t": "equation",
          "text_ru": "m(р-ра) = m(р.в.) + m(воды)"
        },
        {
          "t": "equation",
          "text_ru": "m(р.в.) = ω × m(р-ра) / 100%"
        },
        {
          "t": "paragraph",
          "text_ru": "При разбавлении: масса растворённого вещества не меняется, а масса раствора увеличивается."
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "20 г соли в 200 г раствора → ω = 20/200 × 100% = 10%"
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "К 200 г 10%-ного раствора добавили 300 г воды → m(р.в.) = 20 г, m(р-ра) = 500 г → ω = 20/500 × 100% = 4%"
        }
      ]
    },
    {
      "id": "stoichiometry",
      "title_ru": "Расчёты по уравнению реакции",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Алгоритм расчёта по уравнению реакции:"
        },
        {
          "t": "ordered_list",
          "items_ru": [
            "Записать уравнение реакции, расставить коэффициенты.",
            "Найти количество вещества (n) данного вещества: n = m / M.",
            "По коэффициентам уравнения найти n искомого вещества.",
            "Найти массу (или объём) искомого вещества: m = n × M."
          ]
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "CaCO₃ → CaO + CO₂. Сколько CaO из 200 г CaCO₃? n(CaCO₃) = 200/100 = 2 моль → n(CaO) = 2 моль → m(CaO) = 2 × 56 = 112 г"
        }
      ]
    },
    {
      "id": "yield",
      "title_ru": "Выход продукта реакции",
      "blocks": [
        {
          "t": "paragraph",
          "text_ru": "Выход продукта (η) — отношение практически полученной массы продукта к теоретически возможной."
        },
        {
          "t": "equation",
          "text_ru": "η = m(практ.) / m(теорет.) × 100%"
        },
        {
          "t": "equation",
          "text_ru": "m(практ.) = m(теорет.) × η / 100%"
        },
        {
          "t": "paragraph",
          "text_ru": "Теоретическая масса — рассчитанная по уравнению реакции (η = 100%). На практике выход всегда меньше 100% из-за потерь и побочных реакций."
        },
        {
          "t": "example_block",
          "label_ru": "Пример:",
          "content_ru": "По расчёту должно получиться 112 г CaO, а получено 89,6 г → η = 89,6/112 × 100% = 80%"
        }
      ]
    }
  ]
}
