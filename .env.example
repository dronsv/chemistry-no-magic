# IndexNow key for instant indexing via Yandex and Bing.
#
# Setup:
#   1. Generate a UUID: python3 -c "import uuid; print(uuid.uuid4().hex)"
#      or use any random string (32+ hex chars)
#   2. Set the key here
#   3. Run npm run deploy — the key file public/{key}.txt is created automatically
#   4. Verify at: https://www.bing.com/indexnow/getstarted
#
INDEXNOW_KEY=your-key-here
